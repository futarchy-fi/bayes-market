{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DS3zjrKqDaNGRCmo4P6szu","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from \"vitest\";\n2\timport { renderHook, act } from \"@testing-library/react\";\n3\timport { HistoryProvider, useHistory, HISTORY_CAP } from \"@/features/history/HistoryContext\";\n4\timport type { Command } from \"@/features/history/commands\";\n5\timport type { ReactNode } from \"react\";\n6\t\n7\tfunction wrapper({ children }: { children: ReactNode }) {\n8\t  return <HistoryProvider>{children}</HistoryProvider>;\n9\t}\n10\t\n11\tfunction makeCommand(desc = \"test\"): Command & { executeCalls: number; undoCalls: number } {\n12\t  const cmd = {\n13\t    description: desc,\n14\t    executeCalls: 0,\n15\t    undoCalls: 0,\n16\t    execute() { cmd.executeCalls++; },\n17\t    undo() { cmd.undoCalls++; },\n18\t  };\n19\t  return cmd;\n20\t}\n21\t\n22\tdescribe(\"HistoryContext\", () => {\n23\t  describe(\"initial state\", () => {\n24\t    it(\"starts with empty stacks\", () => {\n25\t      const { result } = renderHook(() => useHistory(), { wrapper });\n26\t      expect(result.current.canUndo).toBe(false);\n27\t      expect(result.current.canRedo).toBe(false);\n28\t      expect(result.current.undoStack).toEqual([]);\n29\t      expect(result.current.redoStack).toEqual([]);\n30\t    });\n31\t  });\n32\t\n33\t  describe(\"push\", () => {\n34\t    it(\"adds a command to the undo stack\", () => {\n35\t      const { result } = renderHook(() => useHistory(), { wrapper });\n36\t      const cmd = makeCommand();\n37\t      act(() => result.current.push(cmd));\n38\t      expect(result.current.canUndo).toBe(true);\n39\t      expect(result.current.undoStack).toHaveLength(1);\n40\t    });\n41\t\n42\t    it(\"clears the redo stack on push\", () => {\n43\t      const { result } = renderHook(() => useHistory(), { wrapper });\n44\t      const cmd1 = makeCommand(\"first\");\n45\t      const cmd2 = makeCommand(\"second\");\n46\t      act(() => result.current.push(cmd1));\n47\t      act(() => result.current.undo());\n48\t      expect(result.current.canRedo).toBe(true);\n49\t      act(() => result.current.push(cmd2));\n50\t      expect(result.current.canRedo).toBe(false);\n51\t      expect(result.current.redoStack).toEqual([]);\n52\t    });\n53\t  });\n54\t\n55\t  describe(\"undo\", () => {\n56\t    it(\"calls undo() on the most recent command\", () => {\n57\t      const { result } = renderHook(() => useHistory(), { wrapper });\n58\t      const cmd = makeCommand();\n59\t      act(() => result.current.push(cmd));\n60\t      act(() => result.current.undo());\n61\t      expect(cmd.undoCalls).toBe(1);\n62\t    });\n63\t\n64\t    it(\"moves command from undo to redo stack\", () => {\n65\t      const { result } = renderHook(() => useHistory(), { wrapper });\n66\t      const cmd = makeCommand();\n67\t      act(() => result.current.push(cmd));\n68\t      act(() => result.current.undo());\n69\t      expect(result.current.canUndo).toBe(false);\n70\t      expect(result.current.canRedo).toBe(true);\n71\t      expect(result.current.redoStack).toHaveLength(1);\n72\t    });\n73\t\n74\t    it(\"is a no-op when undo stack is empty\", () => {\n75\t      const { result } = renderHook(() => useHistory(), { wrapper });\n76\t      act(() => result.current.undo());\n77\t      expect(result.current.canUndo).toBe(false);\n78\t    });\n79\t  });\n80\t\n81\t  describe(\"redo\", () => {\n82\t    it(\"calls execute() on the most recently undone command\", () => {\n83\t      const { result } = renderHook(() => useHistory(), { wrapper });\n84\t      const cmd = makeCommand();\n85\t      act(() => result.current.push(cmd));\n86\t      act(() => result.current.undo());\n87\t      act(() => result.current.redo());\n88\t      expect(cmd.executeCalls).toBe(1);\n89\t    });\n90\t\n91\t    it(\"moves command from redo to undo stack\", () => {\n92\t      const { result } = renderHook(() => useHistory(), { wrapper });\n93\t      const cmd = makeCommand();\n94\t      act(() => result.current.push(cmd));\n95\t      act(() => result.current.undo());\n96\t      act(() => result.current.redo());\n97\t      expect(result.current.canUndo).toBe(true);\n98\t      expect(result.current.canRedo).toBe(false);\n99\t    });\n100\t\n101\t    it(\"is a no-op when redo stack is empty\", () => {\n102\t      const { result } = renderHook(() => useHistory(), { wrapper });\n103\t      act(() => result.current.redo());\n104\t      expect(result.current.canRedo).toBe(false);\n105\t    });\n106\t  });\n107\t\n108\t  describe(\"clear\", () => {\n109\t    it(\"empties both stacks\", () => {\n110\t      const { result } = renderHook(() => useHistory(), { wrapper });\n111\t      act(() => result.current.push(makeCommand()));\n112\t      act(() => result.current.push(makeCommand()));\n113\t      act(() => result.current.undo());\n114\t      act(() => result.current.clear());\n115\t      expect(result.current.canUndo).toBe(false);\n116\t      expect(result.current.canRedo).toBe(false);\n117\t    });\n118\t  });\n119\t\n120\t  describe(\"cap at HISTORY_CAP\", () => {\n121\t    it(`caps the undo stack at ${HISTORY_CAP}`, () => {\n122\t      const { result } = renderHook(() => useHistory(), { wrapper });\n123\t      for (let i = 0; i < HISTORY_CAP + 10; i++) {\n124\t        act(() => result.current.push(makeCommand(`cmd-${i}`)));\n125\t      }\n126\t      expect(result.current.undoStack).toHaveLength(HISTORY_CAP);\n127\t      // The oldest commands should have been evicted\n128\t      expect(result.current.undoStack[0]!.description).toBe(\"cmd-10\");\n129\t    });\n130\t  });\n131\t\n132\t  describe(\"multiple undo/redo cycle\", () => {\n133\t    it(\"correctly sequences undo then redo across 3 commands\", () => {\n134\t      const { result } = renderHook(() => useHistory(), { wrapper });\n135\t      const cmds = [makeCommand(\"a\"), makeCommand(\"b\"), makeCommand(\"c\")];\n136\t      for (const c of cmds) act(() => result.current.push(c));\n137\t\n138\t      // Undo all\n139\t      act(() => result.current.undo());\n140\t      expect(cmds[2]!.undoCalls).toBe(1);\n141\t      act(() => result.current.undo());\n142\t      expect(cmds[1]!.undoCalls).toBe(1);\n143\t      act(() => result.current.undo());\n144\t      expect(cmds[0]!.undoCalls).toBe(1);\n145\t\n146\t      expect(result.current.canUndo).toBe(false);\n147\t      expect(result.current.redoStack).toHaveLength(3);\n148\t\n149\t      // Redo first two\n150\t      act(() => result.current.redo());\n151\t      expect(cmds[0]!.executeCalls).toBe(1);\n152\t      act(() => result.current.redo());\n153\t      expect(cmds[1]!.executeCalls).toBe(1);\n154\t\n155\t      expect(result.current.undoStack).toHaveLength(2);\n156\t      expect(result.current.redoStack).toHaveLength(1);\n157\t    });\n158\t  });\n159\t\n160\t  describe(\"useHistory outside provider\", () => {\n161\t    const originalError = console.error;\n162\t    beforeEach(() => { console.error = vi.fn(); });\n163\t    afterEach(() => { console.error = originalError; });\n164\t\n165\t    it(\"throws when used outside HistoryProvider\", () => {\n166\t      expect(() => renderHook(() => useHistory())).toThrow(\n167\t        \"useHistory must be used within HistoryProvider\",\n168\t      );\n169\t    });\n170\t  });\n171\t});\n172\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"d23d2196-e091-4bab-acad-daa150c62eb0","timestamp":"2026-04-11T21:29:02.427Z"}
