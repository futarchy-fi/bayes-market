{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NNLdWvmdkjRJdktjXnCY5R","type":"tool_result","content":"1\timport { useMarkets } from \"@/lib/query/hooks\";\n2\timport { useAssumptions } from \"./AssumptionContext\";\n3\timport { AssumptionBar } from \"./AssumptionBar\";\n4\timport { VariableRow } from \"./VariableRow\";\n5\timport type { Market } from \"@/lib/api/types\";\n6\t\n7\tinterface AssumptionPanelProps {\n8\t  market: Market;\n9\t}\n10\t\n11\texport function AssumptionPanel({ market }: AssumptionPanelProps) {\n12\t  const { data: marketsData } = useMarkets();\n13\t  const { assumptions } = useAssumptions();\n14\t\n15\t  const allMarkets = marketsData?.markets ?? [];\n16\t  const activeMarkets = allMarkets.filter((m) => m.status === \"active\");\n17\t\n18\t  // Show current market first, then others\n19\t  const sortedIds = [\n20\t    market.id,\n21\t    ...activeMarkets.filter((m) => m.id !== market.id).map((m) => m.id),\n22\t  ];\n23\t\n24\t  return (\n25\t    <div style={panelStyle}>\n26\t      <div style={{ display: \"flex\", justifyContent: \"space-between\", alignItems: \"baseline\", marginBottom: \"var(--space-sm)\" }}>\n27\t        <h3 style={{ fontSize: \"1rem\", fontWeight: 600 }}>\n28\t          Variables & Assumptions\n29\t        </h3>\n30\t        <span style={{ fontSize: \"0.75rem\", color: \"var(--color-text-muted)\" }}>\n31\t          {assumptions.length > 0\n32\t            ? `Showing conditionals given ${assumptions.length} assumption${assumptions.length > 1 ? \"s\" : \"\"}`\n33\t            : \"Showing marginal probabilities\"}\n34\t        </span>\n35\t      </div>\n36\t\n37\t      <AssumptionBar />\n38\t\n39\t      <div style={{ display: \"grid\", gap: \"var(--space-sm)\", marginTop: \"var(--space-sm)\" }}>\n40\t        {sortedIds.map((id) => (\n41\t          <VariableRow key={id} marketId={id} targetMarket={market} />\n42\t        ))}\n43\t      </div>\n44\t\n45\t      {activeMarkets.length <= 1 && (\n46\t        <div style={{ fontSize: \"0.8rem\", color: \"var(--color-text-muted)\", textAlign: \"center\", padding: \"var(--space-md)\" }}>\n47\t          Create more markets to use assumptions — assumptions let you condition on other variables.\n48\t        </div>\n49\t      )}\n50\t    </div>\n51\t  );\n52\t}\n53\t\n54\tconst panelStyle: React.CSSProperties = {\n55\t  padding: \"var(--space-md)\",\n56\t  borderRadius: \"var(--radius-md)\",\n57\t  border: \"1px solid var(--color-border)\",\n58\t  background: \"var(--color-bg-surface)\",\n59\t};\n60\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"dc03c81c-39d6-4fe5-9a48-1d7779203add","timestamp":"2026-04-11T21:29:17.006Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PhY4p1sjScULvFqq8EpFpr","type":"tool_result","content":"1\timport { useAssumptions } from \"./AssumptionContext\";\n2\t\n3\texport function AssumptionBar() {\n4\t  const { assumptions, removeAssumption, clearAll } = useAssumptions();\n5\t\n6\t  if (assumptions.length === 0) return null;\n7\t\n8\t  return (\n9\t    <div style={barStyle}>\n10\t      <span style={{ fontSize: \"0.75rem\", fontWeight: 600, color: \"var(--color-text-muted)\", marginRight: 8 }}>\n11\t        GIVEN:\n12\t      </span>\n13\t      <div style={{ display: \"flex\", flexWrap: \"wrap\", gap: 6, flex: 1 }}>\n14\t        {assumptions.map((a) => (\n15\t          <span key={a.variableId} style={tagStyle}>\n16\t            {a.label} = {a.outcomeId}\n17\t            <button\n18\t              onClick={() => removeAssumption(a.variableId)}\n19\t              style={tagCloseStyle}\n20\t              aria-label={`Remove assumption ${a.label}`}\n21\t            >\n22\t              ×\n23\t            </button>\n24\t          </span>\n25\t        ))}\n26\t      </div>\n27\t      <button onClick={clearAll} style={clearBtnStyle}>\n28\t        Clear all\n29\t      </button>\n30\t    </div>\n31\t  );\n32\t}\n33\t\n34\tconst barStyle: React.CSSProperties = {\n35\t  display: \"flex\",\n36\t  alignItems: \"center\",\n37\t  padding: \"8px 12px\",\n38\t  borderRadius: \"var(--radius-md)\",\n39\t  background: \"rgba(59, 130, 246, 0.08)\",\n40\t  border: \"1px solid rgba(59, 130, 246, 0.25)\",\n41\t  gap: 8,\n42\t};\n43\t\n44\tconst tagStyle: React.CSSProperties = {\n45\t  display: \"inline-flex\",\n46\t  alignItems: \"center\",\n47\t  gap: 4,\n48\t  padding: \"2px 8px\",\n49\t  borderRadius: 4,\n50\t  background: \"var(--color-primary)\",\n51\t  color: \"#fff\",\n52\t  fontSize: \"0.75rem\",\n53\t  fontWeight: 600,\n54\t};\n55\t\n56\tconst tagCloseStyle: React.CSSProperties = {\n57\t  background: \"none\",\n58\t  border: \"none\",\n59\t  color: \"rgba(255,255,255,0.7)\",\n60\t  cursor: \"pointer\",\n61\t  fontSize: \"0.85rem\",\n62\t  padding: \"0 2px\",\n63\t  lineHeight: 1,\n64\t};\n65\t\n66\tconst clearBtnStyle: React.CSSProperties = {\n67\t  background: \"none\",\n68\t  border: \"none\",\n69\t  color: \"var(--color-primary)\",\n70\t  cursor: \"pointer\",\n71\t  fontSize: \"0.75rem\",\n72\t  fontWeight: 500,\n73\t  whiteSpace: \"nowrap\",\n74\t};\n75\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"08fe584e-e132-4bcd-a1fd-a365b2dccbb2","timestamp":"2026-04-11T21:29:17.013Z"}
