{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tqs3UtyHjXhdtrxLx6hUdK","type":"tool_result","content":"1\timport type { Assumption } from \"@/features/assumptions/AssumptionContext\";\n2\t\n3\t/** Generic command interface for undo/redo operations */\n4\texport interface Command {\n5\t  /** Human-readable description of the action */\n6\t  readonly description: string;\n7\t  /** Execute the action */\n8\t  execute(): void;\n9\t  /** Reverse the action */\n10\t  undo(): void;\n11\t}\n12\t\n13\t// ---------------------------------------------------------------------------\n14\t// Assumption commands\n15\t// ---------------------------------------------------------------------------\n16\t\n17\texport class AssumptionAddCommand implements Command {\n18\t  readonly description: string;\n19\t  private readonly assumption: Assumption;\n20\t  private readonly previousAssumption: Assumption | undefined;\n21\t  private readonly doAdd: (a: Assumption) => void;\n22\t  private readonly doRemove: (variableId: string) => void;\n23\t  private readonly doAddBack: (a: Assumption) => void;\n24\t\n25\t  constructor(opts: {\n26\t    assumption: Assumption;\n27\t    previousAssumption: Assumption | undefined;\n28\t    addAssumption: (a: Assumption) => void;\n29\t    removeAssumption: (variableId: string) => void;\n30\t  }) {\n31\t    this.assumption = opts.assumption;\n32\t    this.previousAssumption = opts.previousAssumption;\n33\t    this.doAdd = opts.addAssumption;\n34\t    this.doRemove = opts.removeAssumption;\n35\t    this.doAddBack = opts.addAssumption;\n36\t    this.description = `Assume ${opts.assumption.label} for ${opts.assumption.variableId}`;\n37\t  }\n38\t\n39\t  execute() {\n40\t    this.doAdd(this.assumption);\n41\t  }\n42\t\n43\t  undo() {\n44\t    if (this.previousAssumption) {\n45\t      this.doAddBack(this.previousAssumption);\n46\t    } else {\n47\t      this.doRemove(this.assumption.variableId);\n48\t    }\n49\t  }\n50\t}\n51\t\n52\texport class AssumptionRemoveCommand implements Command {\n53\t  readonly description: string;\n54\t  private readonly removedAssumption: Assumption;\n55\t  private readonly doAdd: (a: Assumption) => void;\n56\t  private readonly doRemove: (variableId: string) => void;\n57\t\n58\t  constructor(opts: {\n59\t    removedAssumption: Assumption;\n60\t    addAssumption: (a: Assumption) => void;\n61\t    removeAssumption: (variableId: string) => void;\n62\t  }) {\n63\t    this.removedAssumption = opts.removedAssumption;\n64\t    this.doAdd = opts.addAssumption;\n65\t    this.doRemove = opts.removeAssumption;\n66\t    this.description = `Remove assumption for ${opts.removedAssumption.variableId}`;\n67\t  }\n68\t\n69\t  execute() {\n70\t    this.doRemove(this.removedAssumption.variableId);\n71\t  }\n72\t\n73\t  undo() {\n74\t    this.doAdd(this.removedAssumption);\n75\t  }\n76\t}\n77\t\n78\texport class AssumptionClearAllCommand implements Command {\n79\t  readonly description = \"Clear all assumptions\";\n80\t  private readonly previousAssumptions: Assumption[];\n81\t  private readonly doSetAll: (assumptions: Assumption[]) => void;\n82\t  private readonly doClear: () => void;\n83\t\n84\t  constructor(opts: {\n85\t    previousAssumptions: Assumption[];\n86\t    setAllAssumptions: (assumptions: Assumption[]) => void;\n87\t    clearAll: () => void;\n88\t  }) {\n89\t    this.previousAssumptions = [...opts.previousAssumptions];\n90\t    this.doSetAll = opts.setAllAssumptions;\n91\t    this.doClear = opts.clearAll;\n92\t  }\n93\t\n94\t  execute() {\n95\t    this.doClear();\n96\t  }\n97\t\n98\t  undo() {\n99\t    this.doSetAll(this.previousAssumptions);\n100\t  }\n101\t}\n102\t\n103\t// ---------------------------------------------------------------------------\n104\t// Probability edit draft commands\n105\t// ---------------------------------------------------------------------------\n106\t\n107\texport interface DraftEdit {\n108\t  entryIndex: number;\n109\t  outcomeId: string;\n110\t  probability: number;\n111\t  context: Array<{ variableId: string; outcomeId: string }>;\n112\t  previousProbability: number;\n113\t  /** True if a draft already existed for this cell before this edit */\n114\t  hadPriorDraft?: boolean;\n115\t}\n116\t\n117\texport class ProbabilityEditCommand implements Command {\n118\t  readonly description: string;\n119\t  private readonly drafts: DraftEdit[];\n120\t  private readonly applyDrafts: (drafts: DraftEdit[]) => void;\n121\t  private readonly revertDrafts: (drafts: DraftEdit[]) => void;\n122\t\n123\t  constructor(opts: {\n124\t    drafts: DraftEdit[];\n125\t    applyDrafts: (drafts: DraftEdit[]) => void;\n126\t    revertDrafts: (drafts: DraftEdit[]) => void;\n127\t    description?: string;\n128\t  }) {\n129\t    this.drafts = opts.drafts;\n130\t    this.applyDrafts = opts.applyDrafts;\n131\t    this.revertDrafts = opts.revertDrafts;\n132\t    this.description = opts.description ?? `Edit ${opts.drafts.length} probability value(s)`;\n133\t  }\n134\t\n135\t  execute() {\n136\t    this.applyDrafts(this.drafts);\n137\t  }\n138\t\n139\t  undo() {\n140\t    this.revertDrafts(this.drafts);\n141\t  }\n142\t}\n143\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"5ad5567f-5877-4d4d-9c23-bbe5dd8a95e7","timestamp":"2026-04-11T21:28:57.508Z"}
