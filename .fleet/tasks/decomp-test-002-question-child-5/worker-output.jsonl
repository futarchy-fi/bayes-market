rket.mockReturnValue(defaultMutationState() as any);\n207\t  mockUseEventTrade.mockReturnValue(defaultMutationState() as any);\n208\t  mockUsePostMarketComment.mockReturnValue(defaultMutationState() as any);\n209\t  mockUseProbabilityEdit.mockReturnValue(defaultMutationState() as any);\n210\t  mockUseCpt.mockReturnValue(defaultQueryState(undefined) as any);\n211\t});\n212\t\n213\tafterEach(() => {\n214\t  vi.useRealTimers();\n215\t});\n216\t\n217\t// ---------------------------------------------------------------------------\n218\t// Tests\n219\t// ---------------------------------------------------------------------------\n220\t\n221\tdescribe(\"MarketDetail\", () => {\n222\t  // ---- Existing tests (refactored to hook-level mocks) ----\n223\t\n224\t  it(\"renders market title and description\", async () => {\n225\t    renderWithProviders(<MarketDetail />);\n226\t    await waitFor(() => {\n227\t      expect(screen.getByRole(\"heading\", { level: 1 })).toHaveTextContent(\"ETH Price > $3000 on March 15\");\n228\t    });\n229\t    expect(screen.getByText(\"Will ETH trade above $3000?\")).toBeInTheDocument();\n230\t  });\n231\t\n232\t  it(\"renders status badge\", async () => {\n233\t    renderWithProviders(<MarketDetail />);\n234\t    await waitFor(() => {\n235\t      expect(screen.getByText(\"active\")).toBeInTheDocument();\n236\t    });\n237\t  });\n238\t\n239\t  it(\"renders outcome probabilities\", async () => {\n240\t    renderWithProviders(<MarketDetail />);\n241\t    await waitFor(() => {\n242\t      expect(screen.getByText(/Yes 65\\.0%/)).toBeInTheDocument();\n243\t    });\n244\t    expect(screen.getByText(/No 35\\.0%/)).toBeInTheDocument();\n245\t  });\n246\t\n247\t  it(\"renders assumptions panel for active market\", async () => {\n248\t    renderWithProviders(<MarketDetail />);\n249\t    await waitFor(() => {\n250\t      expect(screen.getByText(/Variables & Assumptions/)).toBeInTheDocument();\n251\t    });\n252\t  });\n253\t\n254\t  it(\"shows empty events 