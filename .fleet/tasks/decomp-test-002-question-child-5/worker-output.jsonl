   previousAssumption: previous,\n49\t      addAssumption: add,\n50\t      removeAssumption: remove,\n51\t    });\n52\t    cmd.execute();\n53\t    cmd.undo();\n54\t    expect(add).toHaveBeenCalledWith(previous);\n55\t    expect(remove).not.toHaveBeenCalled();\n56\t  });\n57\t});\n58\t\n59\tdescribe(\"AssumptionRemoveCommand\", () => {\n60\t  it(\"execute calls removeAssumption\", () => {\n61\t    const add = vi.fn();\n62\t    const remove = vi.fn();\n63\t    const removed: Assumption = { variableId: \"v1\", outcomeId: \"o1\", label: \"A\" };\n64\t    const cmd = new AssumptionRemoveCommand({\n65\t      removedAssumption: removed,\n66\t      addAssumption: add,\n67\t      removeAssumption: remove,\n68\t    });\n69\t    cmd.execute();\n70\t    expect(remove).toHaveBeenCalledWith(\"v1\");\n71\t  });\n72\t\n73\t  it(\"undo calls addAssumption to restore\", () => {\n74\t    const add = vi.fn();\n75\t    const remove = vi.fn();\n76\t    const removed: Assumption = { variableId: \"v1\", outcomeId: \"o1\", label: \"A\" };\n77\t    const cmd = new AssumptionRemoveCommand({\n78\t      removedAssumption: removed,\n79\t      addAssumption: add,\n80\t      removeAssumption: remove,\n81\t    });\n82\t    cmd.execute();\n83\t    cmd.undo();\n84\t    expect(add).toHaveBeenCalledWith(removed);\n85\t  });\n86\t});\n87\t\n88\tdescribe(\"AssumptionClearAllCommand\", () => {\n89\t  it(\"execute calls clearAll\", () => {\n90\t    const setAll = vi.fn();\n91\t    const clear = vi.fn();\n92\t    const previous: Assumption[] = [\n93\t      { variableId: \"v1\", outcomeId: \"o1\", label: \"A\" },\n94\t      { variableId: \"v2\", outcomeId: \"o2\", label: \"B\" },\n95\t    ];\n96\t    const cmd = new AssumptionClearAllCommand({\n97\t      previousAssumptions: previous,\n98\t      setAllAssumptions: setAll,\n99\t      clearAll: clear,\n100\t    });\n101\t    cmd.execute();\n102\t    expect(clear).toHaveBeenCalled();\n103\t  });\n104\t\n105\t  it(\"undo restores all previous assumptions\", () => {\n106\t    const setAll = vi.fn();\n107\t    const clear = vi.fn();\n108\t    const previous: Assumption[] = [\n109\t      { variableId: \"v1\", outcomeId: \"o1\", label: \"A\" },\n110\t      { variableId: \"v2\", outcomeId: \"o2\", label: \"B\" },\n111\t    ];\n112\t    const cmd = new AssumptionClearAllCommand({\n113\t      previousAssumptions: previous,\n114\t      setAllAssumptions: setAll,\n115\t      clearAll: clear,\n116\t    });\n117\t    cmd.execute();\n118\t    cmd.undo();\n119\t    expect(setAll).toHaveBeenCalledWith(previous);\n120\t  });\n121\t\n122\t  it(\"stores a snapshot of previousAssumptions (not a reference)\", () => {\n123\t    const setAll = vi.fn();\n124\t    const clear = vi.fn();\n125\t    const previous: Assumption[] = [{ variableId: \"v1\", outcomeId: \"o1\", label: \"A\" }];\n126\t    const cmd = new AssumptionClearAllCommand({\n127\t      previousAssumptions: previous,\n128\t      setAllAssumptions: setAll,\n129\t      clearAll: clear,\n130\t    });\n131\t    // Mutate the source array after construction\n132\t    previous.push({ variableId: \"v2\", outcomeId: \"o2\", label: \"B\" });\n133\t    cmd.undo();\n134\t    // Should only have the original 1 element\n135\t    expect(setAll).toHaveBeenCalledWith([{ variableId: \"v1\", outcomeId: \"o1\", label: \"A\" }]);\n136\t  });\n137\t});\n138\t\n139\tdescribe(\"ProbabilityEditCommand\", () => {\n140\t  it(\"execute calls applyDrafts with the drafts\", () => {\n141\t    const apply = vi.fn();\n142\t    const revert = vi.fn();\n143\t    const drafts: DraftEdit[] = [\n144\t      { entryIndex: 0, outcomeId: \"o1\", probability: 0.7, context: [], previousProbability: 0.5 },\n145\t    ];\n146\t    const cmd = new ProbabilityEditCommand({ drafts, applyDrafts: apply, revertDrafts: revert });\n147\t    cmd.execute();\n148\t    expect(apply).toHaveBeenCalledWith(drafts);\n149\t  });\n150\t\n151\t  it(\"undo calls revertDrafts with the drafts\", () => {\n152\t    const apply = vi.fn();\n153\t    const revert = vi.fn();\n154\t    const drafts: DraftEdit[] = [\n155\t      { entryIndex: 0, outcomeId: \"o1\", probability: 0.7, context: [], previousProbability: 0.5 },\n156\t    ];\n157\t    const cmd = new ProbabilityEditCommand({ drafts, applyDrafts: apply, revertDrafts: revert });\n158\t    cmd.execute();\n159\t    cmd.undo();\n160\t    expect(revert).toHaveBeenCalledWith(drafts);\n161\t  });\n162\t\n163\t  it(\"uses custom description when provided\", () => {\n164\t    const cmd = new ProbabilityEditCommand({\n165\t      drafts: [],\n166\t      applyDrafts: vi.fn(),\n167\t      revertDrafts: vi.fn(),\n168\t      description: \"Custom desc\",\n169\t    });\n170\t    expect(cmd.description).toBe(\"Custom desc\");\n171\t  });\n172\t\n173\t  it(\"generates default description from draft count\", () => {\n174\t    const drafts: DraftEdit[] = [\n175\t      { entryIndex: 0, outcomeId: \"o1\", probability: 0.7, context: [], previousProbability: 0.5 },\n176\t      { entryIndex: 1, outcomeId: \"o2\", probability: 0.3, context: [], previousProbability: 0.4 },\n177\t    ];\n178\t    const cmd = new ProbabilityEditCommand({\n179\t      drafts,\n180\t      applyDrafts: vi.fn(),\n181\t      revertDrafts: vi.fn(),\n182\t    });\n183\t    expect(cmd.description).toBe(\"Edit 2 probability value(s)\");\n184\t  });\n185\t});\n186\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"012e5ebf-59be-4bd0-b0fe-db79e4f97419","timestamp":"2026-04-11T21:29:02.574Z"}
