{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BRaMidNCshtk7UxkueumYk","type":"tool_result","content":"1\timport { useState, useCallback } from \"react\";\n2\timport { useOptionalHistory } from \"./HistoryContext\";\n3\timport { ProbabilityEditCommand, type DraftEdit } from \"./commands\";\n4\t\n5\t/**\n6\t * Local draft buffer for probability edits with undo/redo support.\n7\t *\n8\t * Staged edits are stored locally. On undo/redo the draft map is updated.\n9\t * The consumer calls `commit()` to submit all staged drafts to the server.\n10\t */\n11\texport function useDraftEdits() {\n12\t  const history = useOptionalHistory();\n13\t\n14\t  // Map from \"entryIndex::outcomeId\" to drafted probability\n15\t  const [drafts, setDrafts] = useState<Map<string, DraftEdit>>(new Map());\n16\t\n17\t  const draftKey = (entryIndex: number, outcomeId: string) => `${entryIndex}::${outcomeId}`;\n18\t\n19\t  const applyDrafts = useCallback((edits: DraftEdit[]) => {\n20\t    setDrafts((prev) => {\n21\t      const next = new Map(prev);\n22\t      for (const edit of edits) {\n23\t        next.set(draftKey(edit.entryIndex, edit.outcomeId), edit);\n24\t      }\n25\t      return next;\n26\t    });\n27\t  }, []);\n28\t\n29\t  const revertDrafts = useCallback((edits: DraftEdit[]) => {\n30\t    setDrafts((prev) => {\n31\t      const next = new Map(prev);\n32\t      for (const edit of edits) {\n33\t        const key = draftKey(edit.entryIndex, edit.outcomeId);\n34\t        if (!edit.hadPriorDraft) {\n35\t          // No draft existed before this edit — remove it entirely\n36\t          next.delete(key);\n37\t        } else {\n38\t          // Restore to previous draft value\n39\t          next.set(key, { ...edit, probability: edit.previousProbability });\n40\t        }\n41\t      }\n42\t      return next;\n43\t    });\n44\t  }, []);\n45\t\n46\t  const stageDraft = useCallback(\n47\t    (edit: DraftEdit) => {\n48\t      // Look up existing draft to track previous value\n49\t      const key = draftKey(edit.entryIndex, edit.outcomeId);\n50\t      const existing = drafts.get(key);\n51\t      const hadPriorDraft = existing !== undefined;\n52\t      const previousProbability = existing?.probability ?? edit.previousProbability;\n53\t\n54\t      const draftWithPrev: DraftEdit = { ...edit, previousProbability, hadPriorDraft };\n55\t      const cmd = new ProbabilityEditCommand({\n56\t        drafts: [draftWithPrev],\n57\t        applyDrafts,\n58\t        revertDrafts,\n59\t      });\n60\t      cmd.execute();\n61\t      history?.push(cmd);\n62\t    },\n63\t    [drafts, history, applyDrafts, revertDrafts],\n64\t  );\n65\t\n66\t  const getDraft = useCallback(\n67\t    (entryIndex: number, outcomeId: string): number | undefined => {\n68\t      return drafts.get(draftKey(entryIndex, outcomeId))?.probability;\n69\t    },\n70\t    [drafts],\n71\t  );\n72\t\n73\t  const clearDrafts = useCallback(() => {\n74\t    setDrafts(new Map());\n75\t  }, []);\n76\t\n77\t  const hasDrafts = drafts.size > 0;\n78\t\n79\t  const allDrafts = useCallback(() => Array.from(drafts.values()), [drafts]);\n80\t\n81\t  return {\n82\t    stageDraft,\n83\t    getDraft,\n84\t    clearDrafts,\n85\t    hasDrafts,\n86\t    allDrafts,\n87\t    drafts,\n88\t  };\n89\t}\n90\t"}]},"parent_tool_use_id":null,"session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"2f41817d-24db-4d2d-913a-5c0326fee500","timestamp":"2026-04-11T21:30:13.317Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/temporal-worktrees/task-decomp-test-002-question-child-5/frontend/src/features/history/useDraftEdits.ts","content":"import { useState, useCallback } from \"react\";\nimport { useOptionalHistory } from \"./HistoryContext\";\nimport { ProbabilityEditCommand, type DraftEdit } from \"./commands\";\n\n/**\n * Local draft buffer for probability edits with undo/redo support.\n *\n * Staged edits are stored locally. On undo/redo the draft map is updated.\n * The consumer calls `commit()` to submit all staged drafts to the server.\n */\nexport function useDraftEdits() {\n  const history = useOptionalHistory();\n\n  // Map from \"entryIndex::outcomeId\" to drafted probability\n  const [drafts, setDrafts] = useState<Map<string, DraftEdit>>(new Map());\n\n  const draftKey = (entryIndex: number, outcomeId: string) => `${entryIndex}::${outcomeId}`;\n\n  const applyDrafts = useCallback((edits: DraftEdit[]) => {\n    setDrafts((prev) => {\n      const next = new Map(prev);\n      for (const edit of edits) {\n        next.set(draftKey(edit.entryIndex, edit.outcomeId), edit);\n      }\n      return next;\n    });\n  }, []);\n\n  const revertDrafts = useCallback((edits: DraftEdit[]) => {\n    setDrafts((prev) => {\n      const next = new Map(prev);\n      for (const edit of edits) {\n        const key = draftKey(edit.entryIndex, edit.outcomeId);\n        if (!edit.hadPriorDraft) {\n          // No draft existed before this edit — remove it entirely\n          next.delete(key);\n        } else {\n          // Restore to previous draft value\n          next.set(key, { ...edit, probability: edit.previousProbability });\n        }\n      }\n      return next;\n    });\n  }, []);\n\n  const stageDraft = useCallback(\n    (edit: DraftEdit) => {\n      // Look up existing draft to track previous value\n      const key = draftKey(edit.entryIndex, edit.outcomeId);\n      const existing = drafts.get(key);\n      const hadPriorDraft = existing !== undefined;\n      const previousProbability = existing?.probability ?? edit.previousProbability;\n\n      const draftWithPrev: DraftEdit = { ...edit, previousProbability, hadPriorDraft };\n      const cmd = new ProbabilityEditCommand({\n        drafts: [draftWithPrev],\n        applyDrafts,\n        revertDrafts,\n      });\n      cmd.execute();\n      history?.push(cmd);\n    },\n    [drafts, history, applyDrafts, revertDrafts],\n  );\n\n  const getDraft = useCallback(\n    (entryIndex: number, outcomeId: string): number | undefined => {\n      return drafts.get(draftKey(entryIndex, outcomeId))?.probability;\n    },\n    [drafts],\n  );\n\n  const clearDrafts = useCallback(() => {\n    setDrafts(new Map());\n  }, []);\n\n  const hasDrafts = drafts.size > 0;\n\n  const allDrafts = useCallback(() => Array.from(drafts.values()), [drafts]);\n\n  return {\n    stageDraft,\n    getDraft,\n    clearDrafts,\n    hasDrafts,\n    allDrafts,\n    drafts,\n  };\n}\n","numLines":90,"startLine":1,"totalLines":90}}}
