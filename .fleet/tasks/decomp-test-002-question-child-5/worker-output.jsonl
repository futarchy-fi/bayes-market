                   background: isDrafted ? \"rgba(59, 130, 246, 0.06)\" : undefined,\n173\t                      }}\n174\t                      onClick={() => handleCellClick(entryIdx, o.id, p)}\n175\t                    >\n176\t                      <div style={{ display: \"flex\", alignItems: \"center\", gap: 6 }}>\n177\t                        <div style={{\n178\t                          width: 40,\n179\t                          height: 6,\n180\t                          borderRadius: 3,\n181\t                          background: \"var(--color-border)\",\n182\t                          overflow: \"hidden\",\n183\t                        }}>\n184\t                          <div style={{\n185\t                            width: `${Math.max(2, p * 100)}%`,\n186\t                            height: \"100%\",\n187\t                            borderRadius: 3,\n188\t                            background: isDrafted ? \"var(--color-info)\" : p > 0.5 ? \"var(--color-success)\" : \"var(--color-info)\",\n189\t                          }} />\n190\t                        </div>\n191\t                        <span>{formatProbability(p)}{isDrafted ? \" *\" : \"\"}</span>\n192\t                      </div>\n193\t                    </td>\n194\t                  );\n195\t                })}\n196\t              </tr>\n197\t            ))}\n198\t          </tbody>\n199\t        </table>\n200\t      </div>\n201\t\n202\t      {draftEdits.hasDrafts && (\n203\t        <div style={{ display: \"flex\", gap: \"var(--space-sm)\", alignItems: \"center\", marginTop: \"var(--space-sm)\" }}>\n204\t          <button onClick={handleCommitDrafts} disabled={mutation.isPending} style={setBtnStyle}>\n205\t            {mutation.isPending ? \"Submitting…\" : `Commit ${draftEdits.allDrafts().length} draft(s)`}\n206\t          </button>\n207\t          <button onClick={draftEdits.clearDrafts} style={cancelBtnStyle}>Discard drafts</button>\n208\t          <span style={{ fontSize: \"0.75rem\", color: