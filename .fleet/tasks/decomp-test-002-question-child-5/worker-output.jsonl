{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P8NqtWgifTBpv96Fw6xurm","type":"tool_result","content":"1\timport { useCallback } from \"react\";\n2\timport { useAssumptions, type Assumption } from \"@/features/assumptions/AssumptionContext\";\n3\timport { useHistory } from \"./HistoryContext\";\n4\timport { AssumptionAddCommand, AssumptionRemoveCommand, AssumptionClearAllCommand } from \"./commands\";\n5\t\n6\t/**\n7\t * Wraps useAssumptions() with history tracking.\n8\t * Returns the same API surface but each mutation pushes a command onto the undo stack.\n9\t */\n10\texport function useHistoryAssumptions() {\n11\t  const assumptions = useAssumptions();\n12\t  const history = useHistory();\n13\t\n14\t  const addAssumption = useCallback(\n15\t    (a: Assumption) => {\n16\t      const previous = assumptions.getAssumption(a.variableId);\n17\t      const cmd = new AssumptionAddCommand({\n18\t        assumption: a,\n19\t        previousAssumption: previous,\n20\t        addAssumption: assumptions.addAssumption,\n21\t        removeAssumption: assumptions.removeAssumption,\n22\t      });\n23\t      cmd.execute();\n24\t      history.push(cmd);\n25\t    },\n26\t    [assumptions, history],\n27\t  );\n28\t\n29\t  const removeAssumption = useCallback(\n30\t    (variableId: string) => {\n31\t      const existing = assumptions.getAssumption(variableId);\n32\t      if (!existing) return;\n33\t      const cmd = new AssumptionRemoveCommand({\n34\t        removedAssumption: existing,\n35\t        addAssumption: assumptions.addAssumption,\n36\t        removeAssumption: assumptions.removeAssumption,\n37\t      });\n38\t      cmd.execute();\n39\t      history.push(cmd);\n40\t    },\n41\t    [assumptions, history],\n42\t  );\n43\t\n44\t  const clearAll = useCallback(() => {\n45\t    if (assumptions.assumptions.length === 0) return;\n46\t    const cmd = new AssumptionClearAllCommand({\n47\t      previousAssumptions: assumptions.assumptions,\n48\t      setAllAssumptions: assumptions.setAllAssumptions,\n49\t      clearAll: assumptions.clearAll,\n50\t    });\n51\t    cmd.execute();\n52\t    history.push(cmd);\n53\t  }, [assumptions, history]);\n54\t\n55\t  return {\n56\t    ...assumptions,\n57\t    addAssumption,\n58\t    removeAssumption,\n59\t    clearAll,\n60\t  };\n61\t}\n62\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"609c1418-5fad-421a-9e36-abea26a910f5","timestamp":"2026-04-11T21:28:58.441Z"}
