{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013YcePbJdimmp8drDdJxuCi","type":"tool_result","content":"1\timport { describe, it, expect } from \"vitest\";\n2\timport { renderHook, act } from \"@testing-library/react\";\n3\timport { HistoryProvider, useHistory } from \"@/features/history/HistoryContext\";\n4\timport { useDraftEdits } from \"@/features/history/useDraftEdits\";\n5\timport type { ReactNode } from \"react\";\n6\t\n7\tfunction wrapper({ children }: { children: ReactNode }) {\n8\t  return <HistoryProvider>{children}</HistoryProvider>;\n9\t}\n10\t\n11\tfunction useTestHook() {\n12\t  const history = useHistory();\n13\t  const drafts = useDraftEdits();\n14\t  return { history, drafts };\n15\t}\n16\t\n17\tdescribe(\"useDraftEdits\", () => {\n18\t  it(\"starts with no drafts\", () => {\n19\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n20\t    expect(result.current.drafts.hasDrafts).toBe(false);\n21\t    expect(result.current.drafts.allDrafts()).toEqual([]);\n22\t  });\n23\t\n24\t  it(\"staging a draft makes it retrievable\", () => {\n25\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n26\t    act(() => {\n27\t      result.current.drafts.stageDraft({\n28\t        entryIndex: 0,\n29\t        outcomeId: \"o1\",\n30\t        probability: 0.7,\n31\t        context: [],\n32\t        previousProbability: 0.5,\n33\t      });\n34\t    });\n35\t    expect(result.current.drafts.hasDrafts).toBe(true);\n36\t    expect(result.current.drafts.getDraft(0, \"o1\")).toBe(0.7);\n37\t  });\n38\t\n39\t  it(\"staging a draft pushes to history\", () => {\n40\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n41\t    act(() => {\n42\t      result.current.drafts.stageDraft({\n43\t        entryIndex: 0,\n44\t        outcomeId: \"o1\",\n45\t        probability: 0.7,\n46\t        context: [],\n47\t        previousProbability: 0.5,\n48\t      });\n49\t    });\n50\t    expect(result.current.history.canUndo).toBe(true);\n51\t  });\n52\t\n53\t  it(\"undo reverts a staged draft\", () => {\n54\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n55\t    act(() => {\n56\t      result.current.drafts.stageDraft({\n57\t        entryIndex: 0,\n58\t        outcomeId: \"o1\",\n59\t        probability: 0.7,\n60\t        context: [],\n61\t        previousProbability: 0.5,\n62\t      });\n63\t    });\n64\t    act(() => result.current.history.undo());\n65\t    // After undo, draft should be removed (reverted to server value)\n66\t    expect(result.current.drafts.getDraft(0, \"o1\")).toBeUndefined();\n67\t  });\n68\t\n69\t  it(\"redo re-applies a reverted draft\", () => {\n70\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n71\t    act(() => {\n72\t      result.current.drafts.stageDraft({\n73\t        entryIndex: 0,\n74\t        outcomeId: \"o1\",\n75\t        probability: 0.7,\n76\t        context: [],\n77\t        previousProbability: 0.5,\n78\t      });\n79\t    });\n80\t    act(() => result.current.history.undo());\n81\t    act(() => result.current.history.redo());\n82\t    expect(result.current.drafts.getDraft(0, \"o1\")).toBe(0.7);\n83\t  });\n84\t\n85\t  it(\"clearDrafts removes all drafts\", () => {\n86\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n87\t    act(() => {\n88\t      result.current.drafts.stageDraft({\n89\t        entryIndex: 0,\n90\t        outcomeId: \"o1\",\n91\t        probability: 0.7,\n92\t        context: [],\n93\t        previousProbability: 0.5,\n94\t      });\n95\t    });\n96\t    act(() => result.current.drafts.clearDrafts());\n97\t    expect(result.current.drafts.hasDrafts).toBe(false);\n98\t  });\n99\t\n100\t  it(\"multiple drafts for different cells are tracked independently\", () => {\n101\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n102\t    act(() => {\n103\t      result.current.drafts.stageDraft({\n104\t        entryIndex: 0,\n105\t        outcomeId: \"o1\",\n106\t        probability: 0.7,\n107\t        context: [],\n108\t        previousProbability: 0.5,\n109\t      });\n110\t    });\n111\t    act(() => {\n112\t      result.current.drafts.stageDraft({\n113\t        entryIndex: 1,\n114\t        outcomeId: \"o2\",\n115\t        probability: 0.3,\n116\t        context: [],\n117\t        previousProbability: 0.4,\n118\t      });\n119\t    });\n120\t    expect(result.current.drafts.getDraft(0, \"o1\")).toBe(0.7);\n121\t    expect(result.current.drafts.getDraft(1, \"o2\")).toBe(0.3);\n122\t    expect(result.current.drafts.allDrafts()).toHaveLength(2);\n123\t  });\n124\t\n125\t  it(\"works without HistoryProvider (no-op history)\", () => {\n126\t    const { result } = renderHook(() => useDraftEdits());\n127\t    act(() => {\n128\t      result.current.stageDraft({\n129\t        entryIndex: 0,\n130\t        outcomeId: \"o1\",\n131\t        probability: 0.7,\n132\t        context: [],\n133\t        previousProbability: 0.5,\n134\t      });\n135\t    });\n136\t    expect(result.current.getDraft(0, \"o1\")).toBe(0.7);\n137\t  });\n138\t});\n139\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"424f43f7-c161-4399-8933-7cffe2c4ebf0","timestamp":"2026-04-11T21:29:02.798Z"}
