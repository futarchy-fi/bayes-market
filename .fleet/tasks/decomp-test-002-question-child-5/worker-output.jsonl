{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B3LewadR5uKUzGnhD9EGNd","type":"tool_result","content":"1\timport { createContext, useContext, useReducer, useCallback, type ReactNode } from \"react\";\n2\timport type { Command } from \"./commands\";\n3\t\n4\texport const HISTORY_CAP = 50;\n5\t\n6\tinterface HistoryState {\n7\t  undoStack: Command[];\n8\t  redoStack: Command[];\n9\t}\n10\t\n11\ttype HistoryAction =\n12\t  | { type: \"PUSH\"; command: Command }\n13\t  | { type: \"UNDO\" }\n14\t  | { type: \"REDO\" }\n15\t  | { type: \"CLEAR\" };\n16\t\n17\tfunction historyReducer(state: HistoryState, action: HistoryAction): HistoryState {\n18\t  switch (action.type) {\n19\t    case \"PUSH\": {\n20\t      const undoStack = [...state.undoStack, action.command].slice(-HISTORY_CAP);\n21\t      return { undoStack, redoStack: [] };\n22\t    }\n23\t    case \"UNDO\": {\n24\t      if (state.undoStack.length === 0) return state;\n25\t      const undoStack = state.undoStack.slice(0, -1);\n26\t      const command = state.undoStack[state.undoStack.length - 1]!;\n27\t      return { undoStack, redoStack: [...state.redoStack, command] };\n28\t    }\n29\t    case \"REDO\": {\n30\t      if (state.redoStack.length === 0) return state;\n31\t      const redoStack = state.redoStack.slice(0, -1);\n32\t      const command = state.redoStack[state.redoStack.length - 1]!;\n33\t      return { undoStack: [...state.undoStack, command], redoStack };\n34\t    }\n35\t    case \"CLEAR\":\n36\t      return { undoStack: [], redoStack: [] };\n37\t    default:\n38\t      return state;\n39\t  }\n40\t}\n41\t\n42\tinterface HistoryContextValue {\n43\t  /** Push a new command (already executed) onto the undo stack */\n44\t  push: (command: Command) => void;\n45\t  /** Undo the last command */\n46\t  undo: () => void;\n47\t  /** Redo the last undone command */\n48\t  redo: () => void;\n49\t  /** Clear all history */\n50\t  clear: () => void;\n51\t  canUndo: boolean;\n52\t  canRedo: boolean;\n53\t  /** Current undo stack (most recent last) */\n54\t  undoStack: readonly Command[];\n55\t  /** Current redo stack (most recent last) */\n56\t  redoStack: readonly Command[];\n57\t}\n58\t\n59\tconst HistoryCtx = createContext<HistoryContextValue | null>(null);\n60\t\n61\texport function HistoryProvider({ children }: { children: ReactNode }) {\n62\t  const [state, dispatch] = useReducer(historyReducer, { undoStack: [], redoStack: [] });\n63\t\n64\t  const push = useCallback((command: Command) => {\n65\t    dispatch({ type: \"PUSH\", command });\n66\t  }, []);\n67\t\n68\t  const undo = useCallback(() => {\n69\t    const command = state.undoStack[state.undoStack.length - 1];\n70\t    if (command) {\n71\t      command.undo();\n72\t      dispatch({ type: \"UNDO\" });\n73\t    }\n74\t  }, [state.undoStack]);\n75\t\n76\t  const redo = useCallback(() => {\n77\t    const command = state.redoStack[state.redoStack.length - 1];\n78\t    if (command) {\n79\t      command.execute();\n80\t      dispatch({ type: \"REDO\" });\n81\t    }\n82\t  }, [state.redoStack]);\n83\t\n84\t  const clear = useCallback(() => {\n85\t    dispatch({ type: \"CLEAR\" });\n86\t  }, []);\n87\t\n88\t  return (\n89\t    <HistoryCtx.Provider\n90\t      value={{\n91\t        push,\n92\t        undo,\n93\t        redo,\n94\t        clear,\n95\t        canUndo: state.undoStack.length > 0,\n96\t        canRedo: state.redoStack.length > 0,\n97\t        undoStack: state.undoStack,\n98\t        redoStack: state.redoStack,\n99\t      }}\n100\t    >\n101\t      {children}\n102\t    </HistoryCtx.Provider>\n103\t  );\n104\t}\n105\t\n106\texport function useHistory() {\n107\t  const ctx = useContext(HistoryCtx);\n108\t  if (!ctx) throw new Error(\"useHistory must be used within HistoryProvider\");\n109\t  return ctx;\n110\t}\n111\t\n112\t/** Returns the history context or null if not inside a HistoryProvider */\n113\texport function useOptionalHistory() {\n114\t  return useContext(HistoryCtx);\n115\t}\n116\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"2445f44f-d2a5-4a8f-a4ea-3ea9f08a2f5f","timestamp":"2026-04-11T21:28:57.086Z"}
