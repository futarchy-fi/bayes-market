{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011yXxmuVsZFkj3JhzmUjof7","type":"tool_result","content":"1\timport { useHistory } from \"./HistoryContext\";\n2\timport { useUndoRedoKeyboard } from \"./useUndoRedoKeyboard\";\n3\t\n4\texport function UndoRedoToolbar() {\n5\t  const { undo, redo, canUndo, canRedo, undoStack, redoStack } = useHistory();\n6\t  useUndoRedoKeyboard();\n7\t\n8\t  return (\n9\t    <div style={toolbarStyle}>\n10\t      <button\n11\t        onClick={undo}\n12\t        disabled={!canUndo}\n13\t        style={canUndo ? btnStyle : disabledBtnStyle}\n14\t        title={canUndo ? `Undo: ${undoStack[undoStack.length - 1]?.description}` : \"Nothing to undo\"}\n15\t        aria-label=\"Undo\"\n16\t      >\n17\t        Undo\n18\t      </button>\n19\t      <button\n20\t        onClick={redo}\n21\t        disabled={!canRedo}\n22\t        style={canRedo ? btnStyle : disabledBtnStyle}\n23\t        title={canRedo ? `Redo: ${redoStack[redoStack.length - 1]?.description}` : \"Nothing to redo\"}\n24\t        aria-label=\"Redo\"\n25\t      >\n26\t        Redo\n27\t      </button>\n28\t      {(canUndo || canRedo) && (\n29\t        <span style={statusStyle}>\n30\t          {undoStack.length} undo{undoStack.length !== 1 ? \"s\" : \"\"}\n31\t          {canRedo && ` / ${redoStack.length} redo${redoStack.length !== 1 ? \"s\" : \"\"}`}\n32\t        </span>\n33\t      )}\n34\t    </div>\n35\t  );\n36\t}\n37\t\n38\tconst toolbarStyle: React.CSSProperties = {\n39\t  display: \"flex\",\n40\t  alignItems: \"center\",\n41\t  gap: \"var(--space-sm)\",\n42\t  padding: \"var(--space-xs) 0\",\n43\t};\n44\t\n45\tconst btnStyle: React.CSSProperties = {\n46\t  padding: \"4px 12px\",\n47\t  borderRadius: \"var(--radius-sm)\",\n48\t  border: \"1px solid var(--color-border)\",\n49\t  background: \"var(--color-bg-surface)\",\n50\t  color: \"var(--color-text)\",\n51\t  fontSize: \"0.8rem\",\n52\t  fontWeight: 500,\n53\t  cursor: \"pointer\",\n54\t};\n55\t\n56\tconst disabledBtnStyle: React.CSSProperties = {\n57\t  ...btnStyle,\n58\t  opacity: 0.4,\n59\t  cursor: \"default\",\n60\t};\n61\t\n62\tconst statusStyle: React.CSSProperties = {\n63\t  fontSize: \"0.75rem\",\n64\t  color: \"var(--color-text-muted)\",\n65\t};\n66\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"8db0a4e4-e11e-45f5-b244-09135440d093","timestamp":"2026-04-11T21:28:58.191Z"}
