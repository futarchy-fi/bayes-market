{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NNKwoShhRcMsFdJn6pN6uD","type":"tool_result","content":"1\timport { useState } from \"react\";\n2\timport { useCpt, useProbabilityEdit } from \"@/lib/query/hooks\";\n3\timport { useSession } from \"@/features/session/context\";\n4\timport { formatProbability } from \"@/lib/utils/format\";\n5\timport { useDraftEdits } from \"@/features/history/useDraftEdits\";\n6\timport type { Market } from \"@/lib/api/types\";\n7\t\n8\tinterface CptPanelProps {\n9\t  market: Market;\n10\t}\n11\t\n12\tinterface EditingCell {\n13\t  entryIndex: number;\n14\t  outcomeId: string;\n15\t  probability: number;\n16\t}\n17\t\n18\texport function CptPanel({ market }: CptPanelProps) {\n19\t  const { session, isConfigured } = useSession();\n20\t  const { data: cptData, isLoading } = useCpt(market.id);\n21\t  const mutation = useProbabilityEdit(market.id);\n22\t  const [editing, setEditing] = useState<EditingCell | null>(null);\n23\t  const draftEdits = useDraftEdits();\n24\t\n25\t  if (isLoading) {\n26\t    return (\n27\t      <div style={panelStyle}>\n28\t        <h3 style={headerStyle}>Conditional Probability Table</h3>\n29\t        <div style={{ color: \"var(--color-text-muted)\", fontSize: \"0.85rem\" }}>Loading CPT...</div>\n30\t      </div>\n31\t    );\n32\t  }\n33\t\n34\t  if (!cptData) return null;\n35\t\n36\t  const { outcomes, parents, entries } = cptData;\n37\t  const hasParents = parents.length > 0;\n38\t\n39\t  const handleCellClick = (entryIndex: number, outcomeId: string, currentP: number) => {\n40\t    if (!isConfigured) return;\n41\t    setEditing({ entryIndex, outcomeId, probability: currentP });\n42\t  };\n43\t\n44\t  const handleSubmit = () => {\n45\t    if (!editing || !cptData) return;\n46\t    const entry = entries[editing.entryIndex];\n47\t    if (!entry) return;\n48\t\n49\t    const currentP = entry.marginals[editing.outcomeId] ?? 0;\n50\t    draftEdits.stageDraft({\n51\t      entryIndex: editing.entryIndex,\n52\t      outcomeId: editing.outcomeId,\n53\t      probability: editing.probability,\n54\t      context: entry.context,\n55\t      previousProbability: currentP,\n56\t    });\n57\t    setEditing(null);\n58\t  };\n59\t\n60\t  const handleCommitDrafts = () => {\n61\t    const allDrafts = draftEdits.allDrafts();\n62\t    for (const draft of allDrafts) {\n63\t      const entry = entries[draft.entryIndex];\n64\t      if (!entry) continue;\n65\t      mutation.mutate({\n66\t        payload: {\n67\t          accountId: session.accountId,\n68\t          variableId: market.variableId,\n69\t          target: {\n70\t            kind: \"marginal\",\n71\t            outcomeId: draft.outcomeId,\n72\t            probability: draft.probability,\n73\t          },\n74\t          context: draft.context,\n75\t          idempotencyKey: crypto.randomUUID(),\n76\t        },\n77\t        session,\n78\t      });\n79\t    }\n80\t    draftEdits.clearDrafts();\n81\t  };\n82\t\n83\t  const handleCancel = () => setEditing(null);\n84\t\n85\t  return (\n86\t    <div style={panelStyle}>\n87\t      <div style={{ display: \"flex\", justifyContent: \"space-between\", alignItems: \"center\", marginBottom: \"var(--space-sm)\" }}>\n88\t        <h3 style={headerStyle}>Conditional Probability Table</h3>\n89\t        <span style={{ fontSize: \"0.75rem\", color: \"var(--color-text-muted)\" }}>\n90\t          {entries.length} row{entries.length !== 1 ? \"s\" : \"\"}\n91\t          {hasParents && ` \\u00B7 ${parents.length} parent${parents.length !== 1 ? \"s\" : \"\"}`}\n92\t        </span>\n93\t      </div>\n94\t\n95\t      {!hasParents && (\n96\t        <p style={{ fontSize: \"0.8rem\", color: \"var(--color-text-muted)\", marginBottom: \"var(--space-sm)\" }}>\n97\t          No parent variables — showing marginal probabilities.\n98\t        </p>\n99\t      )}\n100\t\n101\t      <div style={{ borderRadius: \"var(--radius-md)\", border: \"1px solid var(--color-border)\", overflow: \"hidden\" }}>\n102\t        <table style={{ width: \"100%\", borderCollapse: \"collapse\", fontSize: \"0.8rem\" }}>\n103\t          <thead>\n104\t            <tr style={{ background: \"var(--color-bg-hover)\" }}>\n105\t              {hasParents && <th style={thStyle}>Condition</th>}\n106\t              {outcomes.map((o) => (\n107\t                <th key={o.id} style={thStyle}>P({o.name})</th>\n108\t              ))}\n109\t            </tr>\n110\t          </thead>\n111\t          <tbody>\n112\t            {entries.map((entry, entryIdx) => (\n113\t              <tr key={entry.contextKey || \"__marginal\"} style={{ borderTop: \"1px solid var(--color-border)\" }}>\n114\t                {hasParents && (\n115\t                  <td style={{ ...tdStyle, fontFamily: \"var(--font-mono)\", fontSize: \"0.75rem\" }}>\n116\t                    {entry.context.map((c) => {\n117\t                      const parent = parents.find((p) => p.variableId === c.variableId);\n118\t                      const outcomeName = parent?.outcomes.find((o) => o.id === c.outcomeId)?.name ?? c.outcomeId;\n119\t                      const parentName = parent?.title ?? c.variableId;\n120\t                      return `${parentName}=${outcomeName}`;\n121\t                    }).join(\", \")}\n122\t                  </td>\n123\t                )}\n124\t                {outcomes.map((o) => {\n125\t                  const serverP = entry.marginals[o.id] ?? 0;\n126\t                  const draftP = draftEdits.getDraft(entryIdx, o.id);\n127\t                  const p = draftP ?? serverP;\n128\t                  const isDrafted = draftP !== undefined;\n129\t                  const isEditing = editing?.entryIndex === entryIdx && editing?.outcomeId === o.id;\n130\t\n131\t                  if (isEditing) {\n132\t                    return (\n133\t                      <td key={o.id} style={tdStyle}>\n134\t                        <div style={{ display: \"flex\", flexDirection: \"column\", gap: 4 }}>\n135\t                          <div style={{ display: \"flex\", alignItems: \"center\", gap: 4 }}>\n136\t                            <input\n137\t                              type=\"range\"\n138\t                              min={0.01}\n139\t                              max={0.99}\n140\t                              step={0.01}\n141\t                              value={editing.probability}\n142\t                              onChange={(e) => setEditing({ ...editing, probability: Number(e.target.value) })}\n143\t                              style={{ flex: 1, minWidth: 60 }}\n144\t                            />\n145\t                            <span style={{ fontFamily: \"var(--font-mono)\", fontSize: \"0.75rem\", minWidth: 40 }}>\n146\t                              {formatProbability(editing.probability)}\n147\t                            </span>\n148\t                          </div>\n149\t                          <div style={{ display: \"flex\", gap: 4 }}>\n150\t                            <button\n151\t                              onClick={handleSubmit}\n152\t                              disabled={mutation.isPending}\n153\t                              style={setBtnStyle}\n154\t                            >\n155\t                              {mutation.isPending ? \"...\" : \"Set\"}\n156\t                            </button>\n157\t                            <button onClick={handleCancel} style={cancelBtnStyle}>Cancel</button>\n158\t                          </div>\n159\t                        </div>\n160\t                      </td>\n161\t                    );\n162\t                  }\n163\t\n164\t                  return (\n165\t                    <td\n166\t                      key={o.id}\n167\t                      style={{\n168\t                        ...tdStyle,\n169\t                        fontFamily: \"var(--font-mono)\",\n170\t                        cursor: isConfigured ? \"pointer\" : \"default\",\n171\t                        position: \"relative\",\n172\t                        background: isDrafted ? \"rgba(59, 130, 246, 0.06)\" : undefined,\n173\t                      }}\n174\t                      onClick={() => handleCellClick(entryIdx, o.id, p)}\n175\t                    >\n176\t                      <div style={{ display: \"flex\", alignItems: \"center\", gap: 6 }}>\n177\t                        <div style={{\n178\t                          width: 40,\n179\t                          height: 6,\n180\t                          borderRadius: 3,\n181\t                          background: \"var(--color-border)\",\n182\t                          overflow: \"hidden\",\n183\t                        }}>\n184\t                          <div style={{\n185\t                            width: `${Math.max(2, p * 100)}%`,\n186\t                            height: \"100%\",\n187\t                            borderRadius: 3,\n188\t                            background: isDrafted ? \"var(--color-info)\" : p > 0.5 ? \"var(--color-success)\" : \"var(--color-info)\",\n189\t                          }} />\n190\t                        </div>\n191\t                        <span>{formatProbability(p)}{isDrafted ? \" *\" : \"\"}</span>\n192\t                      </div>\n193\t                    </td>\n194\t                  );\n195\t                })}\n196\t              </tr>\n197\t            ))}\n198\t          </tbody>\n199\t        </table>\n200\t      </div>\n201\t\n202\t      {draftEdits.hasDrafts && (\n203\t        <div style={{ display: \"flex\", gap: \"var(--space-sm)\", alignItems: \"center\", marginTop: \"var(--space-sm)\" }}>\n204\t          <button onClick={handleCommitDrafts} disabled={mutation.isPending} style={setBtnStyle}>\n205\t            {mutation.isPending ? \"Submitting…\" : `Commit ${draftEdits.allDrafts().length} draft(s)`}\n206\t          </button>\n207\t          <button onClick={draftEdits.clearDrafts} style={cancelBtnStyle}>Discard drafts</button>\n208\t          <span style={{ fontSize: \"0.75rem\", color: \"var(--color-text-muted)\" }}>\n209\t            * = drafted (not yet submitted)\n210\t          </span>\n211\t        </div>\n212\t      )}\n213\t\n214\t      {mutation.isSuccess && (\n215\t        <div style={successStyle}>\n216\t          Edit accepted: {mutation.data.order.orderId}\n217\t        </div>\n218\t      )}\n219\t\n220\t      {mutation.isError && (\n221\t        <div style={errorStyle}>\n222\t          {mutation.error instanceof Error ? mutation.error.message : \"Edit failed\"}\n223\t        </div>\n224\t      )}\n225\t\n226\t      {!isConfigured && (\n227\t        <p style={{ fontSize: \"0.75rem\", color: \"var(--color-text-muted)\", marginTop: \"var(--space-sm)\" }}>\n228\t          Set your Account ID to edit probabilities.\n229\t        </p>\n230\t      )}\n231\t    </div>\n232\t  );\n233\t}\n234\t\n235\tconst panelStyle: React.CSSProperties = {\n236\t  padding: \"var(--space-md)\",\n237\t  borderRadius: \"var(--radius-md)\",\n238\t  border: \"1px solid var(--color-border)\",\n239\t  background: \"var(--color-bg-surface)\",\n240\t};\n241\t\n242\tconst headerStyle: React.CSSProperties = {\n243\t  fontSize: \"1rem\",\n244\t  fontWeight: 600,\n245\t  margin: 0,\n246\t};\n247\t\n248\tconst thStyle: React.CSSProperties = {\n249\t  textAlign: \"left\",\n250\t  padding: \"6px 12px\",\n251\t  fontWeight: 500,\n252\t};\n253\t\n254\tconst tdStyle: React.CSSProperties = {\n255\t  padding: \"6px 12px\",\n256\t};\n257\t\n258\tconst setBtnStyle: React.CSSProperties = {\n259\t  padding: \"2px 8px\",\n260\t  borderRadius: \"var(--radius-sm)\",\n261\t  border: \"none\",\n262\t  background: \"var(--color-primary)\",\n263\t  color: \"#fff\",\n264\t  fontWeight: 600,\n265\t  fontSize: \"0.75rem\",\n266\t  cursor: \"pointer\",\n267\t};\n268\t\n269\tconst cancelBtnStyle: React.CSSProperties = {\n270\t  padding: \"2px 8px\",\n271\t  borderRadius: \"var(--radius-sm)\",\n272\t  border: \"1px solid var(--color-border)\",\n273\t  background: \"transparent\",\n274\t  color: