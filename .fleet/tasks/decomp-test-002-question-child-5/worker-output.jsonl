.message : \"Market not found\"} />;\n30\t  if (!data) return null;\n31\t\n32\t  const m = data.market;\n33\t\n34\t  return (\n35\t    <div style={{ display: \"grid\", gap: \"var(--space-lg)\" }}>\n36\t      <div>\n37\t        <div style={{ display: \"flex\", gap: \"var(--space-md)\", alignItems: \"center\", marginBottom: \"var(--space-sm)\" }}>\n38\t          <h1 style={{ fontSize: \"1.5rem\", fontWeight: 600 }}>{m.title}</h1>\n39\t          <StatusBadge status={m.status} />\n40\t        </div>\n41\t        <p style={{ color: \"var(--color-text-muted)\", marginBottom: \"var(--space-md)\" }}>{m.description}</p>\n42\t        <div style={{ display: \"flex\", gap: \"var(--space-lg)\", fontSize: \"0.85rem\", color: \"var(--color-text-muted)\" }}>\n43\t          <span>Volume: {formatCurrency(m.volume)}</span>\n44\t          <span>Liquidity: {formatCurrency(m.liquidity)}</span>\n45\t          <span>Expires: {timeUntil(m.expires_at)}</span>\n46\t        </div>\n47\t      </div>\n48\t\n49\t      <ProbabilityBar outcomes={m.outcomes} marginals={m.marginals} />\n50\t\n51\t      <PositionCard marketId={m.id} accountRisk={accountRisk.data} isConfigured={isConfigured} />\n52\t\n53\t      <ResolveMarketPanel market={m} />\n54\t\n55\t      {m.status === \"active\" ? (\n56\t        <HistoryProvider>\n57\t          <AssumptionProvider>\n58\t            <UndoRedoToolbar />\n59\t            <AssumptionPanel market={m} />\n60\t            <CptPanel market={m} />\n61\t            <EventTradePanel market={m} />\n62\t            <DiscussionThread market={m} />\n63\t            <ForceDirectedGraph focusMarketId={m.id} />\n64\t          </AssumptionProvider>\n65\t        </HistoryProvider>\n66\t      ) : (\n67\t        <>\n68\t          <CptPanel market={m} />\n69\t          <EventTradePanel market={m} />\n70\t          <DiscussionThread market={m} />\n71\t          <ForceDirectedGraph focusMarketId={m.id} />\n72\t        </>\n73\t      )}\n74\t\n75\t      {/* Event Journal */}\n76\t      <div>\n77\t        <h2 style={{ fontSize: \"1.1rem\", fontWeight: 600, marginBottom: \"var(--space-sm)\" }}>Event Journal</h2>\n78\t        {events.isLoading && <LoadingPage />}\n79\t        {events.data && events.data.events.length === 0 && (\n80\t          <span style={{ color: \"var(--color-text-muted)\", fontSize: \"0.85rem\" }}>No events yet.</span>\n81\t        )}\n82\t        {events.data && events.data.events.length > 0 && (\n83\t          <div style={{ borderRadius: \"var(--radius-md)\", border: \"1px solid var(--color-border)\", overflow: \"hidden\" }}>\n84\t            <table style={{ width: \"100%\", borderCollapse: \"collapse\", fontSize: \"0.8rem\" }}>\n85\t              <thead>\n86\t                <tr style={{ background: \"var(--color-bg-hover)\" }}>\n87\t                  <th style={thStyle}>Seq</th>\n88\t                  <th style={thStyle}>Type</th>\n89\t                  <th style={thStyle}>Hash</th>\n90\t                  <th style={thStyle}>Time</th>\n91\t                </tr>\n92\t              </thead>\n93\t              <tbody>\n94\t                {events.data.events.map((e) => (\n95\t                  <EventRow key={e.eventId} event={e} />\n96\t                ))}\n97\t              </tbody>\n98\t            </table>\n99\t          </div>\n100\t        )}\n101\t      </div>\n102\t\n103\t      <JunctionTreePanel marketId={m.id} />\n104\t    </div>\n105\t  );\n106\t}\n107\t\n108\tfunction PositionCard({\n109\t  marketId,\n110\t  accountRisk,\n111\t  isConfigured,\n112\t}: {\n113\t  marketId: string;\n114\t  accountRisk: import(\"@/lib/api/types\").AccountRiskResponse | undefined;\n115\t  isConfigured: boolean;\n116\t}) {\n117\t  if (!isConfigured || !accountRisk) return null;\n118\t\n119\t  const marketRisk = accountRisk.account.risk.minAssets.markets.find(\n120\t    (mr) => mr.marketId === marketId,\n121\t  );\n122\t\n123\t  if (!marketRisk) return null;\n124\t\n125\t  const utilColor = marketRisk.utilization > 0.8\n126\t    ? \"var(--color-danger)\"\n127\t    : marketRisk.utilization > 0.5\n128\t      ? \"var(--color-warning, orange)\"\n129\t      : \"var(--color-text)\";\n130\t\n131\t  return (\n132\t    <div style={positionCardStyle}>\n133\t      <div style={{ fontSize: \"0.8rem\", fontWeight: 600, marginBottom: \"var(--space-xs)\" }}>\n134\t        Your Position\n135\t      </div>\n136\t      <div style={{ display: \"grid\", gridTemplateColumns: \"repeat(3, 1fr)\", gap: \"var(--space-sm)\", fontSize: \"0.8rem\" }}>\n137\t        <div>\n138\t          <div style={{ color: \"var(--color-text-muted)\", fontSize: \"0.7rem\" }}>Min Asset</div>\n139\t          <div style={{ fontFamily: \"var(--font-mono)\", fontWeight: 600 }}>{marketRisk.minAsset.toFixed(2)}</div>\n140\t        </div>\n141\t        <div>\n142\t          <div style={{ color: \"var(--color-text-muted)\", fontSize: \"0.7rem\" }}>Utilization</div>\n143\t          <div style={{ fontFamily: \"var(--font-mono)\", fontWeight: 600, color: utilColor }}>\n144\t            {(marketRisk.utilization * 100).toFixed(1)}%\n145\t          </div>\n146\t        </div>\n147\t        <div>\n148\t          <div style={{ color: \"var(--color-text-muted)\", fontSize: \"0.7rem\" }}>Trades</div>\n149\t          <div style={{ fontFamily: \"var(--font-mono)\", fontWeight: 600 }}>{marketRisk.commandCount}</div>\n150\t        </div>\n151\t      </div>\n152\t    </div>\n153\t  );\n154\t}\n155\t\n156\tfunction EventRow({ event }: { event: MarketEvent }) {\n157\t  const [expanded, setExpanded] = useState(false);\n158\t  const hasPayload = Object.keys(event.payload).length > 0;\n159\t\n160\t  return (\n161\t    <>\n162\t      <tr\n163\t        onClick={() => hasPayload && setExpanded(!expanded)}\n164\t        style={{ borderTop: \"1px solid var(--color-border)\", cursor: hasPayload ? \"pointer\" : \"default\" }}\n165\t      >\n166\t        <td style={tdStyle}>{event.seq}</td>\n167\t        <td style={tdStyle}>\n168\t          {hasPayload && <span style={{ marginRight: 4