,\n39\t      ]);\n40\t    });\n41\t\n42\t    it(\"adds multiple assumptions with different variableIds\", () => {\n43\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n44\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n45\t      act(() => result.current.addAssumption({ variableId: \"v2\", outcomeId: \"o2\", label: \"L2\" }));\n46\t      expect(result.current.assumptions).toHaveLength(2);\n47\t      expect(result.current.assumptions[0]!.variableId).toBe(\"v1\");\n48\t      expect(result.current.assumptions[1]!.variableId).toBe(\"v2\");\n49\t    });\n50\t\n51\t    it(\"replaces assumption with same variableId\", () => {\n52\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n53\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"Old\" }));\n54\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o2\", label: \"New\" }));\n55\t      expect(result.current.assumptions).toHaveLength(1);\n56\t      expect(result.current.assumptions[0]).toEqual({ variableId: \"v1\", outcomeId: \"o2\", label: \"New\" });\n57\t    });\n58\t  });\n59\t\n60\t  describe(\"removeAssumption\", () => {\n61\t    it(\"removes an existing assumption by variableId\", () => {\n62\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n63\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n64\t      act(() => result.current.removeAssumption(\"v1\"));\n65\t      expect(result.current.assumptions).toEqual([]);\n66\t    });\n67\t\n68\t    it(\"is a no-op when removing non-existent variableId\", () => {\n69\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n70\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n71\t      act(() => result.current.removeAssumption(\"v-nonexistent\"));\n72\t      expect(result.current.assumptions).toHaveLength(1);\n73\t    });\n74\t  });\n75\t\n76\t  describe(\"clearAll\", () => {\n77\t    it(\"removes all assumptions\", () => {\n78\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n79\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n80\t      act(() => result.current.addAssumption({ variableId: \"v2\", outcomeId: \"o2\", label: \"L2\" }));\n81\t      act(() => result.current.clearAll());\n82\t      expect(result.current.assumptions).toEqual([]);\n83\t    });\n84\t  });\n85\t\n86\t  describe(\"hasAssumption and getAssumption\", () => {\n87\t    it(\"hasAssumption returns true for existing variableId\", () => {\n88\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n89\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n90\t      expect(result.current.hasAssumption(\"v1\")).toBe(true);\n91\t    });\n92\t\n93\t    it(\"hasAssumption returns false for missing variableId\", () => {\n94\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n95\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n96\t      expect(result.current.hasAssumption(\"v2\")).toBe(false);\n97\t    });\n98\t\n99\t    it(\"getAssumption returns the matching Assumption\", () => {\n100\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n101\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n102\t      expect(result.current.getAssumption(\"v1\")).toEqual({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" });\n103\t    });\n104\t\n105\t    it(\"getAssumption returns undefined for missing variableId\", () => {\n106\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n107\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n108\t      expect(result.current.getAssumption(\"v2\")).toBeUndefined();\n109\t    });\n110\t  });\n111\t\n112\t  describe(\"contextPayload\", () => {\n113\t    it(\"contains only variableId and outcomeId (no label)\", () => {\n114\t      const { result } = renderHook(() => useAssumptions(), { wrapper });\n115\t      act(() => result.current.addAssumption({ variableId: \"v1\", outcomeId: \"o1\", label: \"L1\" }));\n116\t      act(() => result.current.addAssumption({ variableId: \"v2\", outcomeId: \"o2\", label: \"L2\" }));\n117\t      expect(result.current.contextPayload).toEqual([\n118\t        { variableId: \"v1\", outcomeId: \"o1\" },\n119\t        { variableId: \"v2\", outcomeId: \"o2\" },\n120\t      ]);\n121\t    });\n122\t  });\n123\t\n124\t  describe(\"useAssumptions outside provider\", () => {\n125\t    const originalError = console.error;\n126\t    beforeEach(() => { console.error = vi.fn(); });\n127\t    afterEach(() => { console.error = originalError; });\n128\t\n129\t    it(\"throws when used outside AssumptionProvider\", () => {\n130\t      expect(() => renderHook(() => useAssumptions())).toThrow(\n131\t        \"useAssumptions must be used within AssumptionProvider\",\n132\t      );\n133\t    });\n134\t  });\n135\t});\n136\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"66961c5e-8264-48c6-8cba-90522618bd29","timestamp":"2026-04-11T21:29:09.711Z"}
