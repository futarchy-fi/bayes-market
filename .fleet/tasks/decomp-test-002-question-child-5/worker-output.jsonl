{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012noSjMxK3hg9CmDU6r1H5S","type":"tool_result","content":"1\timport { QueryClient, QueryClientProvider } from \"@tanstack/react-query\";\n2\timport { RouterProvider } from \"react-router-dom\";\n3\timport { SessionProvider } from \"@/features/session/context\";\n4\timport { router } from \"./router\";\n5\timport { routerFuture } from \"./routerFuture\";\n6\timport type { ReactNode } from \"react\";\n7\t\n8\tconst queryClient = new QueryClient({\n9\t  defaultOptions: {\n10\t    queries: {\n11\t      staleTime: 2000,\n12\t      retry: 1,\n13\t    },\n14\t  },\n15\t});\n16\t\n17\texport function Providers({ children }: { children?: ReactNode }) {\n18\t  return (\n19\t    <QueryClientProvider client={queryClient}>\n20\t      <SessionProvider>\n21\t        {children ?? <RouterProvider router={router} future={routerFuture} />}\n22\t      </SessionProvider>\n23\t    </QueryClientProvider>\n24\t  );\n25\t}\n26\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"09365a3a-f695-43f4-a772-1d401f356c01","timestamp":"2026-04-11T21:29:20.285Z"}
