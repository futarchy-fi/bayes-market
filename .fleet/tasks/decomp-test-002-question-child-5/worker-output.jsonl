UseQueryResult<T, Error>>,\n56\t): UseQueryResult<T, Error> {\n57\t  return {\n58\t    data: undefined,\n59\t    error: null,\n60\t    isLoading: false,\n61\t    isSuccess: false,\n62\t    isError: false,\n63\t    isPending: false,\n64\t    isLoadingError: false,\n65\t    isRefetchError: false,\n66\t    status: \"pending\",\n67\t    fetchStatus: \"idle\",\n68\t    isFetching: false,\n69\t    isPlaceholderData: false,\n70\t    isRefetching: false,\n71\t    isStale: false,\n72\t    dataUpdatedAt: 0,\n73\t    errorUpdatedAt: 0,\n74\t    failureCount: 0,\n75\t    failureReason: null,\n76\t    errorUpdateCount: 0,\n77\t    isFetched: false,\n78\t    isFetchedAfterMount: false,\n79\t    isInitialLoading: false,\n80\t    isPaused: false,\n81\t    isEnabled: true,\n82\t    refetch: vi.fn(),\n83\t    promise: Promise.resolve(undefined as never),\n84\t    ...overrides,\n85\t  } as UseQueryResult<T, Error>;\n86\t}\n87\t\n88\texport function createMockMutationResult<TData = unknown, TError = Error, TVariables = unknown, TContext = unknown>(\n89\t  overrides?: Partial<UseMutationResult<TData, TError, TVariables, TContext>>,\n90\t): UseMutationResult<TData, TError, TVariables, TContext> {\n91\t  return {\n92\t    data: undefined,\n93\t    error: null,\n94\t    isError: false,\n95\t    isIdle: true,\n96\t    isPending: false,\n97\t    isSuccess: false,\n98\t    status: \"idle\",\n99\t    variables: undefined,\n100\t    context: undefined,\n101\t    failureCount: 0,\n102\t    failureReason: null,\n103\t    submittedAt: 0,\n104\t    mutate: vi.fn(),\n105\t    mutateAsync: vi.fn(),\n106\t    reset: vi.fn(),\n107\t    isPaused: false,\n108\t    ...overrides,\n109\t  } as UseMutationResult<TData, TError, TVariables, TContext>;\n110\t}\n111\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"08e36688-2d9c-4c55-8523-576772fcbdc9","timestamp":"2026-04-11T21:29:05.214Z"}
