{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EQWedNfnr263Q1aFnwCkA4","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from \"vitest\";\n2\timport { renderHook, act } from \"@testing-library/react\";\n3\timport { HistoryProvider, useHistory } from \"@/features/history/HistoryContext\";\n4\timport { useUndoRedoKeyboard, isEditableElement } from \"@/features/history/useUndoRedoKeyboard\";\n5\timport type { Command } from \"@/features/history/commands\";\n6\timport type { ReactNode } from \"react\";\n7\t\n8\tfunction makeCommand(desc = \"test\"): Command {\n9\t  return {\n10\t    description: desc,\n11\t    execute: vi.fn(),\n12\t    undo: vi.fn(),\n13\t  };\n14\t}\n15\t\n16\tfunction wrapper({ children }: { children: ReactNode }) {\n17\t  return <HistoryProvider>{children}</HistoryProvider>;\n18\t}\n19\t\n20\tfunction useTestHook() {\n21\t  const history = useHistory();\n22\t  useUndoRedoKeyboard();\n23\t  return history;\n24\t}\n25\t\n26\tfunction fireKey(opts: { key: string; ctrlKey?: boolean; metaKey?: boolean; shiftKey?: boolean }) {\n27\t  const event = new KeyboardEvent(\"keydown\", {\n28\t    key: opts.key,\n29\t    ctrlKey: opts.ctrlKey ?? false,\n30\t    metaKey: opts.metaKey ?? false,\n31\t    shiftKey: opts.shiftKey ?? false,\n32\t    bubbles: true,\n33\t    cancelable: true,\n34\t  });\n35\t  document.dispatchEvent(event);\n36\t  return event;\n37\t}\n38\t\n39\tdescribe(\"isEditableElement\", () => {\n40\t  it(\"returns false for null\", () => {\n41\t    expect(isEditableElement(null)).toBe(false);\n42\t  });\n43\t\n44\t  it(\"returns true for INPUT element\", () => {\n45\t    const el = document.createElement(\"input\");\n46\t    expect(isEditableElement(el)).toBe(true);\n47\t  });\n48\t\n49\t  it(\"returns true for TEXTAREA element\", () => {\n50\t    const el = document.createElement(\"textarea\");\n51\t    expect(isEditableElement(el)).toBe(true);\n52\t  });\n53\t\n54\t  it(\"returns true for SELECT element\", () => {\n55\t    const el = document.createElement(\"select\");\n56\t    expect(isEditableElement(el)).toBe(true);\n57\t  });\n58\t\n59\t  it(\"returns true for contenteditable element\", () => {\n60\t    const el = document.createElement(\"div\");\n61\t    el.contentEditable = \"true\";\n62\t    expect(isEditableElement(el)).toBe(true);\n63\t  });\n64\t\n65\t  it(\"returns false for a regular div\", () => {\n66\t    const el = document.createElement(\"div\");\n67\t    expect(isEditableElement(el)).toBe(false);\n68\t  });\n69\t\n70\t  it(\"returns false for a button\", () => {\n71\t    const el = document.createElement(\"button\");\n72\t    expect(isEditableElement(el)).toBe(false);\n73\t  });\n74\t});\n75\t\n76\tdescribe(\"useUndoRedoKeyboard\", () => {\n77\t  it(\"Ctrl+Z triggers undo when history has items\", () => {\n78\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n79\t    const cmd = makeCommand();\n80\t    act(() => result.current.push(cmd));\n81\t    act(() => fireKey({ key: \"z\", ctrlKey: true }));\n82\t    expect(cmd.undo).toHaveBeenCalled();\n83\t  });\n84\t\n85\t  it(\"Ctrl+Shift+Z triggers redo\", () => {\n86\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n87\t    const cmd = makeCommand();\n88\t    act(() => result.current.push(cmd));\n89\t    act(() => result.current.undo());\n90\t    act(() => fireKey({ key: \"z\", ctrlKey: true, shiftKey: true }));\n91\t    expect(cmd.execute).toHaveBeenCalled();\n92\t  });\n93\t\n94\t  it(\"Ctrl+Y triggers redo\", () => {\n95\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n96\t    const cmd = makeCommand();\n97\t    act(() => result.current.push(cmd));\n98\t    act(() => result.current.undo());\n99\t    act(() => fireKey({ key: \"y\", ctrlKey: true }));\n100\t    expect(cmd.execute).toHaveBeenCalled();\n101\t  });\n102\t\n103\t  it(\"Meta+Z triggers undo (Mac)\", () => {\n104\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n105\t    const cmd = makeCommand();\n106\t    act(() => result.current.push(cmd));\n107\t    act(() => fireKey({ key: \"z\", metaKey: true }));\n108\t    expect(cmd.undo).toHaveBeenCalled();\n109\t  });\n110\t\n111\t  it(\"does not trigger undo without Ctrl/Meta\", () => {\n112\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n113\t    const cmd = makeCommand();\n114\t    act(() => result.current.push(cmd));\n115\t    act(() => fireKey({ key: \"z\" }));\n116\t    expect(cmd.undo).not.toHaveBeenCalled();\n117\t  });\n118\t\n119\t  it(\"does not trigger when activeElement is an input\", () => {\n120\t    const input = document.createElement(\"input\");\n121\t    document.body.appendChild(input);\n122\t    input.focus();\n123\t\n124\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n125\t    const cmd = makeCommand();\n126\t    act(() => result.current.push(cmd));\n127\t    act(() => fireKey({ key: \"z\", ctrlKey: true }));\n128\t    expect(cmd.undo).not.toHaveBeenCalled();\n129\t\n130\t    document.body.removeChild(input);\n131\t  });\n132\t\n133\t  it(\"does not trigger when activeElement is a textarea\", () => {\n134\t    const textarea = document.createElement(\"textarea\");\n135\t    document.body.appendChild(textarea);\n136\t    textarea.focus();\n137\t\n138\t    const { result } = renderHook(() => useTestHook(), { wrapper });\n139\t    const cmd = makeCommand();\n140\t    act(() => result.current.push(cmd));\n141\t    act(() => fireKey({ key: \"z\", ctrlKey: true }));\n142\t    expect(cmd.undo).not.toHaveBeenCalled();\n143\t\n144\t    document.body.removeChild(textarea);\n145\t  });\n146\t});\n147\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"62aa217a-0620-44a6-a75e-6c49045b3d02","timestamp":"2026-04-11T21:29:03.008Z"}
