{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013bYkjR5MD3nAuZhAhhrfSw","type":"tool_result","content":"1\timport { useEffect } from \"react\";\n2\timport { useHistory } from \"./HistoryContext\";\n3\t\n4\t/**\n5\t * Returns true if the active element is an input/textarea/select/contenteditable,\n6\t * meaning native browser undo should be used instead.\n7\t */\n8\texport function isEditableElement(el: Element | null): boolean {\n9\t  if (!el) return false;\n10\t  const tag = el.tagName;\n11\t  if (tag === \"INPUT\" || tag === \"TEXTAREA\" || tag === \"SELECT\") return true;\n12\t  if ((el as HTMLElement).isContentEditable || (el as HTMLElement).contentEditable === \"true\") return true;\n13\t  return false;\n14\t}\n15\t\n16\t/**\n17\t * Listens for Ctrl+Z (undo) and Ctrl+Shift+Z / Ctrl+Y (redo) on the document.\n18\t * Skips events when an editable element is focused.\n19\t */\n20\texport function useUndoRedoKeyboard() {\n21\t  const { undo, redo, canUndo, canRedo } = useHistory();\n22\t\n23\t  useEffect(() => {\n24\t    function handleKeyDown(e: KeyboardEvent) {\n25\t      if (isEditableElement(document.activeElement)) return;\n26\t\n27\t      const isCtrl = e.ctrlKey || e.metaKey;\n28\t      if (!isCtrl) return;\n29\t\n30\t      if (e.key === \"z\" && !e.shiftKey) {\n31\t        if (canUndo) {\n32\t          e.preventDefault();\n33\t          undo();\n34\t        }\n35\t      } else if ((e.key === \"z\" && e.shiftKey) || e.key === \"y\") {\n36\t        if (canRedo) {\n37\t          e.preventDefault();\n38\t          redo();\n39\t        }\n40\t      }\n41\t    }\n42\t\n43\t    document.addEventListener(\"keydown\", handleKeyDown);\n44\t    return () => document.removeEventListener(\"keydown\", handleKeyDown);\n45\t  }, [undo, redo, canUndo, canRedo]);\n46\t}\n47\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"688c321f-843d-4a2f-a0e3-f9febd7e57d5","timestamp":"2026-0