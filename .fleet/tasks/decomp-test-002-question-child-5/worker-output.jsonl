{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vrnxq6jv6c7pZZxgJPVFr9","type":"tool_result","content":"1\timport { useState, useCallback } from \"react\";\n2\timport { useOptionalHistory } from \"./HistoryContext\";\n3\timport { ProbabilityEditCommand, type DraftEdit } from \"./commands\";\n4\t\n5\t/**\n6\t * Local draft buffer for probability edits with undo/redo support.\n7\t *\n8\t * Staged edits are stored locally. On undo/redo the draft map is updated.\n9\t * The consumer calls `commit()` to submit all staged drafts to the server.\n10\t */\n11\texport function useDraftEdits() {\n12\t  const history = useOptionalHistory();\n13\t\n14\t  // Map from \"entryIndex::outcomeId\" to drafted probability\n15\t  const [drafts, setDrafts] = useState<Map<string, DraftEdit>>(new Map());\n16\t\n17\t  const draftKey = (entryIndex: number, outcomeId: string) => `${entryIndex}::${outcomeId}`;\n18\t\n19\t  const applyDrafts = useCallback((edits: DraftEdit[]) => {\n20\t    setDrafts((prev) => {\n21\t      const next = new Map(prev);\n22\t      for (const edit of edits) {\n23\t        next.set(draftKey(edit.entryIndex, edit.outcomeId), edit);\n24\t      }\n25\t      return next;\n26\t    });\n27\t  }, []);\n28\t\n29\t  const revertDrafts = useCallback((edits: DraftEdit[]) => {\n30\t    setDrafts((prev) => {\n31\t      const next = new Map(prev);\n32\t      for (const edit of edits) {\n33\t        const key = draftKey(edit.entryIndex, edit.outcomeId);\n34\t        if (!edit.hadPriorDraft) {\n35\t          // No draft existed before this edit — remove it entirely\n36\t          next.delete(key);\n37\t        } else {\n38\t          // Restore to previous draft value\n39\t          next.set(key, { ...edit, probability: edit.previousProbability });\n40\t        }\n41\t      }\n42\t      return next;\n43\t    });\n44\t  }, []);\n45\t\n46\t  const stageDraft = useCallback(\n47\t    (edit: DraftEdit) => {\n48\t      // Look up existing draft to track previous value\n49\t      const key = draftKey(edit.entryIndex, edit.outcomeId);\n50\t      const existing = drafts.get(key);\n51\t      const hadPriorDraft = existing !== undefined;\n52\t      const previousProbability = existing?.probability ?? edit.previousProbability;\n53\t\n54\t      const draftWithPrev: DraftEdit = { ...edit, previousProbability, hadPriorDraft };\n55\t      const cmd = new ProbabilityEditCommand({\n56\t        drafts: [draftWithPrev],\n57\t        applyDrafts,\n58\t        revertDrafts,\n59\t      });\n60\t      cmd.execute();\n61\t      history?.push(cmd);\n62\t    },\n63\t    [drafts, history, applyDrafts, revertDrafts],\n64\t  );\n65\t\n66\t  const getDraft = useCallback(\n67\t    (entryIndex: number, outcomeId: string): number | undefined => {\n68\t      return drafts.get(draftKey(entryIndex, outcomeId))?.probability;\n69\t    },\n70\t    [drafts],\n71\t  );\n72\t\n73\t  const clearDrafts = useCallback(() => {\n74\t    setDrafts(new Map());\n75\t  }, []);\n76\t\n77\t  const hasDrafts = drafts.size > 0;\n78\t\n79\t  const allDrafts = useCallback(() => Array.from(drafts.values()), [drafts]);\n80\t\n81\t  return {\n82\t    stageDraft,\n83\t    getDraft,\n84\t    clearDrafts,\n85\t    hasDrafts,\n86\t    allDrafts,\n87\t    drafts,\n88\t  };\n89\t}\n90\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"0bb2ab79-7bf4-4f05-8920-6dea624d70e6","timestamp":"2026-04-11T21:28:57.743Z"}
