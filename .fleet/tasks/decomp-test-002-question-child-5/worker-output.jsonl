g.entryIndex,\n52\t      outcomeId: editing.outcomeId,\n53\t      probability: editing.probability,\n54\t      context: entry.context,\n55\t      previousProbability: currentP,\n56\t    });\n57\t    setEditing(null);\n58\t  };\n59\t\n60\t  const handleCommitDrafts = () => {\n61\t    const allDrafts = draftEdits.allDrafts();\n62\t    for (const draft of allDrafts) {\n63\t      const entry = entries[draft.entryIndex];\n64\t      if (!entry) continue;\n65\t      mutation.mutate({\n66\t        payload: {\n67\t          accountId: session.accountId,\n68\t          variableId: market.variableId,\n69\t          target: {\n70\t            kind: \"marginal\",\n71\t            outcomeId: draft.outcomeId,\n72\t            probability: draft.probability,\n73\t          },\n74\t          context: draft.context,\n75\t          idempotencyKey: crypto.randomUUID(),\n76\t        },\n77\t        session,\n78\t      });\n79\t    }\n80\t    draftEdits.clearDrafts();\n81\t  };\n82\t\n83\t  const handleCancel = () => setEditing(null);\n84\t\n85\t  return (\n86\t    <div style={panelStyle}>\n87\t      <div style={{ display: \"flex\", justifyContent: \"space-between\", alignItems: \"center\", marginBottom: \"var(--space-sm)\" }}>\n88\t        <h3 style={headerStyle}>Conditional Probability Table</h3>\n89\t        <span style={{ fontSize: \"0.75rem\", color: \"var(--color-text-muted)\" }}>\n90\t          {entries.length} row{entries.length !== 1 ? \"s\" : \"\"}\n91\t          {hasParents && ` \\u00B7 ${parents.length} parent${parents.length !== 1 ? \"s\" : \"\"}`}\n92\t        </span>\n93\t      </div>\n94\t\n95\t      {!hasParents && (\n96\t        <p style={{ fontSize: \"0.8rem\", color: \"var(--color-text-muted)\", marginBottom: \"var(--space-sm)\" }}>\n97\t          No parent variables — showing marginal probabilities.\n98\t        </p>\n99\t      )}\n100\t\n101\t      <div style={{ borderRadius: \"var(--radius-md)\", border: \"1px solid var(--color-border)\", overflow: \"hidden\" }}>\n