{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017Xw3ZmSH5vbWbjNHGaVuKS","type":"tool_result","content":"1\timport { createContext, useContext, useState, useCallback, type ReactNode } from \"react\";\n2\t\n3\texport interface Assumption {\n4\t  variableId: string;\n5\t  outcomeId: string;\n6\t  /** Display label for the assumption */\n7\t  label: string;\n8\t}\n9\t\n10\tinterface AssumptionState {\n11\t  assumptions: Assumption[];\n12\t  addAssumption: (a: Assumption) => void;\n13\t  removeAssumption: (variableId: string) => void;\n14\t  clearAll: () => void;\n15\t  /** Restore a full set of assumptions (used by undo) */\n16\t  setAllAssumptions: (assumptions: Assumption[]) => void;\n17\t  hasAssumption: (variableId: string) => boolean;\n18\t  getAssumption: (variableId: string) => Assumption | undefined;\n19\t  /** Context array for API calls */\n20\t  contextPayload: Array<{ variableId: string; outcomeId: string }>;\n21\t}\n22\t\n23\tconst AssumptionCtx = createContext<AssumptionState | null>(null);\n24\t\n25\texport function AssumptionProvider({ children }: { children: ReactNode }) {\n26\t  const [assumptions, setAssumptions] = useState<Assumption[]>([]);\n27\t\n28\t  const addAssumption = useCallback((a: Assumption) => {\n29\t    setAssumptions((prev) => {\n30\t      const filtered = prev.filter((p) => p.variableId !== a.variableId);\n31\t      return [...filtered, a];\n32\t    });\n33\t  }, []);\n34\t\n35\t  const removeAssumption = useCallback((variableId: string) => {\n36\t    setAssumptions((prev) => prev.filter((p) => p.variableId !== variableId));\n37\t  }, []);\n38\t\n39\t  const clearAll = useCallback(() => setAssumptions([]), []);\n40\t\n41\t  const setAllAssumptions = useCallback((all: Assumption[]) => setAssumptions(all), []);\n42\t\n43\t  const hasAssumption = useCallback(\n44\t    (variableId: string) => assumptions.some((a) => a.variableId === variableId),\n45\t    [assumptions],\n46\t  );\n47\t\n48\t  const getAssumption = useCallback(\n49\t    (variableId: string) => assumptions.find((a) => a.variableId === variableId),\n50\t    [assumptions],\n51\t  );\n52\t\n53\t  const contextPayload = assumptions.map((a) => ({\n54\t    variableId: a.variableId,\n55\t    outcomeId: a.outcomeId,\n56\t  }));\n57\t\n58\t  return (\n59\t    <AssumptionCtx.Provider\n60\t      value={{ assumptions, addAssumption, removeAssumption, clearAll, setAllAssumptions, hasAssumption, getAssumption, contextPayload }}\n61\t    >\n62\t      {children}\n63\t    </AssumptionCtx.Provider>\n64\t  );\n65\t}\n66\t\n67\texport function useAssumptions() {\n68\t  const ctx = useContext(AssumptionCtx);\n69\t  if (!ctx) throw new Error(\"useAssumptions must be used within AssumptionProvider\");\n70\t  return ctx;\n71\t}\n72\t"}]},"parent_tool_use_id":"toolu_016WuaECKs6GTej4YUcAoznP","session_id":"79b66f7c-c2e7-4ea1-bea2-f0ef0430de4d","uuid":"0c9d4eb8-aa76-433e-b938-da0e25576e91","timestamp":"2026-04-11T21:28:54.341Z"}
