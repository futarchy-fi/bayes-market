{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GbrCNmtbWMhnUe3QyaTDVv","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"Pure LMSR math helpers for probability-edit quoting.\"\"\"\n3\t\n4\tfrom __future__ import annotations\n5\t\n6\timport math\n7\tfrom typing import Any, Mapping\n8\t\n9\tPROBABILITY_SUM_TOLERANCE = 1e-9\n10\t\n11\t\n12\tdef _validate_distribution(\n13\t    distribution: Mapping[str, Any],\n14\t    *,\n15\t    name: str,\n16\t    require_strictly_positive: bool,\n17\t) -> dict[str, float]:\n18\t    if not isinstance(distribution, dict):\n19\t        raise ValueError(f\"{name} must be a dictionary\")\n20\t\n21\t    if len(distribution) < 2:\n22\t        raise ValueError(f\"{name} must contain at least two outcomes\")\n23\t\n24\t    normalized: dict[str, float] = {}\n25\t    for outcome_id, value in distribution.items():\n26\t        normalized_outcome_id = str(outcome_id)\n27\t        if not normalized_outcome_id:\n28\t            raise ValueError(f\"{name} outcome ids must be non-empty strings\")\n29\t        if normalized_outcome_id in normalized:\n30\t            raise ValueError(f\"{name} outcome ids must be unique\")\n31\t        if isinstance(value, bool) or not isinstance(value, (int, float)):\n32\t            raise ValueError(f\"{name} must contain numeric values for all outcomes\")\n33\t        probability = float(value)\n34\t        if not math.isfinite(probability):\n35\t            raise ValueError(f\"{name} must contain finite numeric values for all outcomes\")\n36\t        normalized[normalized_outcome_id] = probability\n37\t\n38\t    if require_strictly_positive:\n39\t        if any(probability <= 0.0 for probability in normalized.values()):\n40\t            raise ValueError(f\"{name} must contain strictly positive probabilities for all outcomes\")\n41\t    else:\n42\t        if any(probability < 0.0 for probability in normalized.values()):\n43\t            raise ValueError(f\"{name} must contain non-negative probabilities for all outcomes\")\n44\t\n45\t    if not math.isclose(sum(normalized.values()), 1.0, abs_tol=PROBABILITY_SUM_TOLERANCE):\n46\t        raise ValueError(f\"{name} must sum to 1.0\")\n47\t\n48\t    return normalized\n49\t\n50\t\n51\tdef _validate_target_probability(target_probability: Any) -> float:\n52\t    if isinstance(target_probability, bool) or not isinstance(target_probability, (int, float)):\n53\t        raise ValueError(\"target_probability must be a number\")\n54\t\n55\t    normalized_probability = float(target_probability)\n56\t    if not math.isfinite(normalized_probability):\n57\t        raise ValueError(\"target_probability must be finite\")\n58\t    if not (0.0 < normalized_probability < 1.0):\n59\t        raise ValueError(\"target_probability must be greater than 0 and less than 1\")\n60\t    return normalized_probability\n61\t\n62\t\n63\tdef _validate_liquidity(liquidity: Any) -> float:\n64\t    if isinstance(liquidity, bool) or not isinstance(liquidity, (int, float)):\n65\t        raise ValueError(\"liquidity must be a number\")\n66\t\n67\t    normalized_liquidity = float(liquidity)\n68\t    if not math.isfinite(normalized_liquidity):\n69\t        raise ValueError(\"liquidity must be finite\")\n70\t    if normalized_liquidity <= 0.0:\n71\t        raise ValueError(\"liquidity must be greater than 0\")\n72\t    return normalized_liquidity\n73\t\n74\t\n75\tdef _validate_quote_inputs(\n76\t    previous: Mapping[str, Any],\n77\t    updated: Mapping[str, Any],\n78\t) -> tuple[dict[str, float], dict[str, float]]:\n79\t    normalized_previous = _validate_distribution(\n80\t        previous,\n81\t        name=\"previous\",\n82\t        require_strictly_positive=True,\n83\t    )\n84\t    normalized_updated = _validate_distribution(\n85\t        updated,\n86\t        name=\"updated\",\n87\t        require_strictly_positive=True,\n88\t    )\n89\t    if set(normalized_previous) != set(normalized_updated):\n90\t        raise ValueError(\"previous and updated must contain the same outcomes\")\n91\t    return normalized_previous, normalized_updated\n92\t\n93\t\n94\tdef rescale_probability_edit(\n95\t    previous: Mapping[str, Any],\n96\t    outcome_id: str,\n97\t    target_probability: float,\n98\t) -> dict[str, float]:\n99\t    \"\"\"Rescale a distribution so one outcome reaches a target probability.\"\"\"\n100\t    normalized_previous = _validate_distribution(\n101\t        previous,\n102\t        name=\"previous\",\n103\t        require_strictly_positive=False,\n104\t    )\n105\t    normalized_target_probability = _validate_target_probability(target_probability)\n106\t    normalized_outcome_id = str(outcome_id)\n107\t\n108\t    if normalized_outcome_id not in normalized_previous:\n109\t        raise ValueError(\"outcome_id must match a known outcome\")\n110\t\n111\t    other_outcome_ids = [candidate for candidate in normalized_previous if candidate != normalized_outcome_id]\n112\t    if not other_outcome_ids:\n113\t        raise ValueError(\"previous must contain at least two outcomes\")\n114\t\n115\t    previous_other_total = sum(normalized_previous[candidate] for candidate in other_outcome_ids)\n116\t    remaining_probability = 1.0 - normalized_target_probability\n117\t    if previous_other_total <= 0.0:\n118\t        scaled_others = {\n119\t            candidate: remaining_probability / len(other_outcome_ids) for candidate in other_outcome_ids\n120\t        }\n121\t    else:\n122\t        scaled_others = {\n123\t            candidate: normalized_previous[candidate] / previous_other_total * remaining_probability\n124\t            for candidate in other_outcome_ids\n125\t        }\n126\t\n127\t    updated = {normalized_outcome_id: normalized_target_probability, **scaled_others}\n128\t    rounding_drift = 1.0 - sum(updated.values())\n129\t    if rounding_drift != 0.0:\n130\t        updated[other_outcome_ids[-1]] += rounding_drift\n131\t    return updated\n132\t\n133\t\n134\tdef lmsr_score_d