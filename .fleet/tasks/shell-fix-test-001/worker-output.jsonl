  f.write('DATABASE_URL=mysql://localhost/mydb\\n')\n49\t            env_path = f.name\n50\t        cfg = load_config(env_path=env_path)\n51\t        assert cfg['APP_NAME'] == 'FromDotenv'\n52\t        assert cfg['DEBUG'] is True\n53\t        assert cfg['DATABASE_URL'] == 'mysql://localhost/mydb'\n54\t    finally:\n55\t        os.unlink(env_path)\n56\t        for k, v in old.items():\n57\t            if v is not None:\n58\t                os.environ[k] = v\n59\t\n60\t\n61\tdef test_env_vars_override_dotenv():\n62\t    old = {k: os.environ.pop(k, None) for k in ('APP_NAME', 'DEBUG', 'DATABASE_URL')}\n63\t    os.environ['APP_NAME'] = 'FromEnv'\n64\t    try:\n65\t        with tempfile.NamedTemporaryFile(mode='w', suffix='.env', delete=False) as f:\n66\t            f.write('APP_NAME=FromDotenv\\n')\n67\t            f.write('DEBUG=1\\n')\n68\t            env_path = f.name\n69\t        cfg = load_config(env_path=env_path)\n70\t        assert cfg['APP_NAME'] == 'FromEnv'\n71\t        assert cfg['DEBUG'] is True\n72\t    finally:\n73\t        os.unlink(env_path)\n74\t        os.environ.pop('APP_NAME', None)\n75\t        for k, v in old.items():\n76\t            if v is not None:\n77\t                os.environ[k] = v\n78\t\n79\t\n80\tdef test_parse_bool():\n81\t    assert parse_bool('true') is True\n82\t    assert parse_bool('True') is True\n83\t    assert parse_bool('1') is True\n84\t    assert parse_bool('yes') is True\n85\t    assert parse_bool('on') is True\n86\t    assert parse_bool('false') is False\n87\t    assert parse_bool('0') is False\n88\t    assert parse_bool('no') is False\n89\t    assert parse_bool('off') is False\n90\t    assert parse_bool(None) is False\n91\t    assert parse_bool(None, default=True) is True\n92\t\n93\t\n94\tdef test_parse_dotenv_comments_and_blanks():\n95\t    with tempfile.NamedTemporaryFile(mode='w', suffix='.env', delete=False) as f:\n96\t        f.write('# this is a comment\\n')\n97\t        f.write('\\n')\n98\t        f.write('KEY=valu