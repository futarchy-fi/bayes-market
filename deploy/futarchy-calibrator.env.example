# Exchange calibrator reference environment.
#
# Create an ordinary service account named "calibrator" and give it initial
# credits with an external admin mint. Store only that account's bearer key
# here; top-ups remain an external operator action. Keep the existing timer
# cadence unchanged when switching its service from paper to exchange mode.

FUTARCHY_API_URL=http://127.0.0.1:3210
FUTARCHY_API_KEY=<calibrator-service-account-key>
CALIBRATOR_MIN_BALANCE=100
CALIBRATOR_RUN_BUDGET=50
CALIBRATOR_MIN_GAP=0.01

# Existing anchor refresh and logging settings still apply.
# METACULUS_TOKEN=<optional-token>
# CAL_ANCHORS=scripts/import/data/anchors.json
# CAL_LOG=scripts/calibrator/trades.jsonl
